{
  "name": "customer-cohort-ltv-analyst",
  "display_name": "客户 Cohort 与 LTV 分析师",
  "type": "portable-business-skill",
  "scope": "cross-platform",
  "version": "1.0.0",
  "owner_project": "SkillForge",
  "portable": true,
  "entrypoint": "SKILL.md",
  "category_path": [
    "数据",
    "业务分析"
  ],
  "description": "按获客 cohort、复购周期和贡献利润评估客户留存与长期价值。 Use when an AI needs to handle 复购和留存分析, 渠道客户质量比较, CAC 回收和 LTV 预测; produce cohort 留存表, LTV/CAC 和回收期, 分层策略与不确定性; and apply evidence, explicit boundaries, validation, and rollback instead of generic advice.",
  "search_keywords": [
    "复购和留存分析",
    "渠道客户质量比较",
    "CAC 回收和 LTV 预测",
    "客户身份与 cohort 定义",
    "复购、留存和间隔",
    "收入、毛利和贡献 LTV"
  ],
  "supported_platforms": [
    "Claude",
    "Codex",
    "GPT",
    "Manus",
    "Trae",
    "Qorder"
  ],
  "inputs": {
    "required": [
      "业务目标、范围和现状证据"
    ],
    "optional": [
      "历史数据、流程系统资料、目标、预算、SLA 和合规约束"
    ]
  },
  "outputs": [
    "cohort 留存表",
    "LTV/CAC 和回收期",
    "分层策略与不确定性",
    "决策、执行、验收、风险和未知项记录"
  ],
  "implementation": {
    "readme": "README.md",
    "entry_doc": "SKILL.md",
    "invocation_doc": "INVOCATION.md",
    "script": "",
    "config": "",
    "base_prompt": "BASE_PROMPT.md",
    "examples_dir": "examples",
    "eval_dir": "eval",
    "platform_adapters_dir": "platforms"
  },
  "constraints": [
    "不得用尚未成熟 cohort 的短期收入直接外推长期 LTV。",
    "不得虚构事实、数据、权限、实施或验证结果",
    "必须明确口径、责任、验收、风险和未知项"
  ],
  "distribution": {
