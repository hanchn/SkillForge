{
  "name": "customer-service-voice-manager",
  "display_name": "跨境客售前后运营专家",
  "type": "portable-business-skill",
  "scope": "cross-platform",
  "version": "2.0.6",
  "owner_project": "SkillForge",
  "portable": true,
  "entrypoint": "SKILL.md",
  "category_path": [
    "客售前后",
    "客服运营"
  ],
  "description": "端到端完成购买前咨询、商品推荐、订单中服务、售后处理、多语言沟通、知识沉淀、质检培训和跨部门交接。适用于邮件、聊天和平台消息的售前售中售后接待、商品推荐、订单查询、异议、退款退货与多语言沟通、客服知识库、投诉升级、线索交接和质量改进，交付客售前后答复与处理方案、客服 SOP、FAQ、话术、权限和升级矩阵、咨询、售后、质检、培训与 VOC 改进报告。",
  "search_keywords": [
    "邮件、聊天和平台消息的售前售中售后接待",
    "商品推荐、订单查询、异议、退款退货与多语言沟通",
    "客服知识库、投诉升级、线索交接和质量改进",
    "客户意图、订单阶段和硬约束",
    "商品、价格、库存、订单、履约与政策事实",
    "语言、文化、隐私、情绪和品牌语气"
  ],
  "supported_platforms": [
    "Claude",
    "Codex",
    "GPT",
    "Manus",
    "Trae",
    "Qorder"
  ],
  "inputs": {
    "required": [
      "业务目标、范围和现状证据"
    ],
    "optional": [
      "历史数据、流程系统资料、目标、预算、SLA 和合规约束"
    ]
  },
  "outputs": [
    "客售前后答复与处理方案",
    "客服 SOP、FAQ、话术、权限和升级矩阵",
    "咨询、售后、质检、培训与 VOC 改进报告",
    "决策、执行、验收、风险和未知项记录"
  ],
  "implementation": {
    "readme": "README.md",
    "entry_doc": "SKILL.md",
    "invocation_doc": "INVOCATION.md",
    "script": "",
    "config": "",
    "base_prompt": "BASE_PROMPT.md",
    "examples_dir": "examples",
    "eval_dir": "eval",
    "platform_adapters_dir": "platforms"
  },
  "constraints": [
    "不得为转化或平息投诉虚构功能、现货、折扣、送达、退款、赔付或保修承诺；不得机械直译、过度采集个人数据或仅以响应时长评价服务。",
    "不得虚构事实、数据、权限、实施或验证结果",
    "必须明确口径、责任、验收、风险和未知项"
  ],
  "distribution": {
    "share_as_single_folder": true,
    "required_files": [
      "SKILL.md",
      "skill.json",
      "README.md",
      "INVOCATION.md",
      "BASE_PROMPT.md"
    ],
    "package_files": [
      "BASE_PROMPT.md",
      "INVOCATION.md",
      "README.md",
      "SKILL.md",
      "agents/openai.yaml",
      "assets/data-source-intake-template.md",
      "assets/decision-record-template.md",
      "assets/delivery-template.md",
      "eval/acceptance.md",
      "examples/README.md",
      "platforms/README.md",
      "references/compliance-baseline.md",
      "references/data-source-and-api-gate.md",
      "references/professional-checklist.md",
      "references/scenario-playbook.md",
      "skill.json"
    ]
  },
  "compliance": {
    "profile": "customer-presales",
    "baseline": "references/compliance-baseline.md",
    "decision_states": [
      "ALLOW",
      "REVIEW_REQUIRED",
      "COMPLIANCE_REJECTED"
    ],
    "human_review_required_when_uncertain": true,
    "does_not_replace_system_controls_or_professional_advice": true
  }
}
