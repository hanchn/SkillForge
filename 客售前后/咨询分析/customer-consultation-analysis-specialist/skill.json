{
  "name": "customer-consultation-analysis-specialist",
  "display_name": "客户咨询分析专家",
  "type": "portable-business-skill",
  "scope": "cross-platform",
  "version": "1.0.0",
  "owner_project": "SkillForge",
  "portable": true,
  "entrypoint": "SKILL.md",
  "category_path": [
    "客售前后",
    "咨询分析"
  ],
  "description": "把授权的售前、售中、售后咨询与订单、商品、履约、退款和评价事实关联，识别客户意图、知识缺口、转化障碍、服务异常和可验证改进机会。适用于客服会话与咨询主题分析、高频问题、未解决咨询和转化障碍诊断、咨询、订单、售后、评价与 VOC 联合分析，交付咨询数据质量与口径报告、意图主题、问题严重度和根因分析、知识、商品、流程、培训和系统改进闭环。",
  "search_keywords": [
    "客服会话与咨询主题分析",
    "高频问题、未解决咨询和转化障碍诊断",
    "咨询、订单、售后、评价与 VOC 联合分析",
    "渠道、语言、站点、时间和会话口径",
    "意图、主题、情绪、解决状态和证据片段",
    "咨询与订单、转化、退款、评价的可比关联"
  ],
  "supported_platforms": [
    "Claude",
    "Codex",
    "GPT",
    "Manus",
    "Trae",
    "Qorder"
  ],
  "inputs": {
    "required": [
      "业务目标、范围和现状证据"
    ],
    "optional": [
      "历史数据、流程系统资料、目标、预算、SLA 和合规约束"
    ]
  },
  "outputs": [
    "咨询数据质量与口径报告",
    "意图主题、问题严重度和根因分析",
    "知识、商品、流程、培训和系统改进闭环",
    "决策、执行、验收、风险和未知项记录"
  ],
  "implementation": {
    "readme": "README.md",
    "entry_doc": "SKILL.md",
    "invocation_doc": "INVOCATION.md",
    "script": "",
    "config": "",
    "base_prompt": "BASE_PROMPT.md",
    "examples_dir": "examples",
    "eval_dir": "eval",
    "platform_adapters_dir": "platforms"
  },
  "constraints": [
    "不得把情绪自动等同于客户价值或投诉责任，不得用敏感属性画像客户；缺少会话授权、统一口径、订单关联或代表性样本时只能输出数据缺口与抽检计划。",
    "不得虚构事实、数据、权限、实施或验证结果",
    "必须明确口径、责任、验收、风险和未知项"
  ],
  "distribution": {
    "share_as_single_folder": true,
    "required_files": [
      "SKILL.md",
      "skill.json",
      "README.md",
      "INVOCATION.md",
      "BASE_PROMPT.md"
    ],
    "package_files": [
      "BASE_PROMPT.md",
      "INVOCATION.md",
      "README.md",
      "SKILL.md",
      "agents/openai.yaml",
      "assets/data-source-intake-template.md",
      "assets/decision-record-template.md",
      "assets/delivery-template.md",
      "eval/acceptance.md",
      "examples/README.md",
      "platforms/README.md",
      "references/compliance-baseline.md",
      "references/data-source-and-api-gate.md",
      "references/professional-checklist.md",
      "references/scenario-playbook.md",
      "skill.json"
    ]
  },
  "compliance": {
    "profile": "customer-presales",
    "baseline": "references/compliance-baseline.md",
    "decision_states": [
      "ALLOW",
      "REVIEW_REQUIRED",
      "COMPLIANCE_REJECTED"
    ],
    "human_review_required_when_uncertain": true,
    "does_not_replace_system_controls_or_professional_advice": true
  }
}
