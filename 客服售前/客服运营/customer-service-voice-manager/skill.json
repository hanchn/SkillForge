{
  "name": "customer-service-voice-manager",
  "display_name": "跨境客服售前运营专家",
  "type": "portable-business-skill",
  "scope": "cross-platform",
  "version": "2.0.2",
  "owner_project": "SkillForge",
  "portable": true,
  "entrypoint": "SKILL.md",
  "category_path": [
    "客服售前",
    "客服运营"
  ],
  "description": "端到端完成跨渠道购买前咨询、需求澄清、商品推荐、多语言回复、FAQ 沉淀、线索分级、质检培训和销售交接。适用于邮件、聊天和平台消息售前接待、商品推荐、异议处理与多语言沟通、客服知识库、线索交接和质量改进，交付售前答复与商品推荐方案、客服 SOP、FAQ、话术和权限矩阵、线索、质检、培训与 VOC 改进报告。",
  "search_keywords": [
    "邮件、聊天和平台消息售前接待",
    "商品推荐、异议处理与多语言沟通",
    "客服知识库、线索交接和质量改进",
    "客户场景、预算和硬约束",
    "商品、价格、库存、履约与政策事实",
    "语言、文化、隐私和品牌语气"
  ],
  "supported_platforms": [
    "Claude",
    "Codex",
    "GPT",
    "Manus",
    "Trae",
    "Qorder"
  ],
  "inputs": {
    "required": [
      "业务目标、范围和现状证据"
    ],
    "optional": [
      "历史数据、流程系统资料、目标、预算、SLA 和合规约束"
    ]
  },
  "outputs": [
    "售前答复与商品推荐方案",
    "客服 SOP、FAQ、话术和权限矩阵",
    "线索、质检、培训与 VOC 改进报告",
    "决策、执行、验收、风险和未知项记录"
  ],
  "implementation": {
    "readme": "README.md",
    "entry_doc": "SKILL.md",
    "invocation_doc": "INVOCATION.md",
    "script": "",
    "config": "",
    "base_prompt": "BASE_PROMPT.md",
    "examples_dir": "examples",
    "eval_dir": "eval",
    "platform_adapters_dir": "platforms"
  },
  "constraints": [
    "不得为转化虚构功能、现货、折扣、送达或保修承诺；不得机械直译、过度采集个人数据或仅以响应时长评价服务。",
    "不得虚构事实、数据、权限、实施或验证结果",
    "必须明确口径、责任、验收、风险和未知项"
  ],
  "distribution": {
    "share_as_single_folder": true,
    "required_files": [
      "SKILL.md",
      "skill.json",
      "README.md",
      "INVOCATION.md",
      "BASE_PROMPT.md"
    ],
    "package_files": [
      "BASE_PROMPT.md",
      "INVOCATION.md",
      "README.md",
      "SKILL.md",
      "agents/openai.yaml",
      "assets/decision-record-template.md",
      "assets/delivery-template.md",
      "eval/acceptance.md",
      "examples/README.md",
      "platforms/README.md",
      "references/compliance-baseline.md",
      "references/professional-checklist.md",
      "references/scenario-playbook.md",
      "skill.json"
    ]
  },
  "compliance": {
    "profile": "customer-presales",
    "baseline": "references/compliance-baseline.md",
    "decision_states": [
      "ALLOW",
      "REVIEW_REQUIRED",
      "COMPLIANCE_REJECTED"
    ],
    "human_review_required_when_uncertain": true,
    "does_not_replace_system_controls_or_professional_advice": true
  }
}
