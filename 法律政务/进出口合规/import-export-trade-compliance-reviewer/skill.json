{
  "name": "import-export-trade-compliance-reviewer",
  "display_name": "进出口贸易合规审查顾问",
  "type": "portable-business-skill",
  "scope": "cross-platform",
  "version": "1.0.0",
  "owner_project": "SkillForge",
  "portable": true,
  "entrypoint": "SKILL.md",
  "category_path": [
    "法律政务",
    "进出口合规"
  ],
  "description": "对跨境货物流的进口、出口、再出口、海关、制裁与出口管制责任进行证据化审查。适用于新品或新国家进出口审查、报关资料和责任链复核、制裁、许可证或出口管制红旗处理，交付进出口合规审查报告、商品、主体、路线和责任矩阵、证据缺口、暂停条件和专业升级清单。",
  "search_keywords": [
    "新品或新国家进出口审查",
    "报关资料和责任链复核",
    "制裁、许可证或出口管制红旗处理",
    "出口方、进口商和最终受益人",
    "商品描述、HS、原产地和估价",
    "目的地、最终用户和最终用途"
  ],
  "supported_platforms": [
    "Claude",
    "Codex",
    "GPT",
    "Manus",
    "Trae",
    "Qorder"
  ],
  "inputs": {
    "required": [
      "业务目标、范围和现状证据"
    ],
    "optional": [
      "历史数据、流程系统资料、目标、预算、SLA 和合规约束"
    ]
  },
  "outputs": [
    "进出口合规审查报告",
    "商品、主体、路线和责任矩阵",
    "证据缺口、暂停条件和专业升级清单",
    "决策、执行、验收、风险和未知项记录"
  ],
  "implementation": {
    "readme": "README.md",
    "entry_doc": "SKILL.md",
    "invocation_doc": "INVOCATION.md",
    "script": "",
    "config": "",
    "base_prompt": "BASE_PROMPT.md",
    "examples_dir": "examples",
    "eval_dir": "eval",
    "platform_adapters_dir": "platforms"
  },
  "constraints": [
    "不得代替报关行、分类专家或执业律师作最终申报；分类、原产地、估价、制裁命中和许可证不明时必须暂停并升级。",
    "不得虚构事实、数据、权限、实施或验证结果",
    "必须明确口径、责任、验收、风险和未知项"
  ],
  "distribution": {
    "share_as_single_folder": true,
    "required_files": [
      "SKILL.md",
      "skill.json",
      "README.md",
      "INVOCATION.md",
      "BASE_PROMPT.md"
    ],
    "package_files": [
      "BASE_PROMPT.md",
      "INVOCATION.md",
      "README.md",
      "SKILL.md",
      "agents/openai.yaml",
      "assets/delivery-template.md",
      "eval/acceptance.md",
      "examples/README.md",
      "platforms/README.md",
      "references/professional-checklist.md",
      "skill.json"
    ]
  }
}
