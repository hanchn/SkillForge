{
  "name": "contract-risk-reviewer",
  "display_name": "合同风险审阅师",
  "type": "portable-business-skill",
  "scope": "cross-platform",
  "version": "1.0.2",
  "owner_project": "SkillForge",
  "portable": true,
  "entrypoint": "SKILL.md",
  "category_path": [
    "法律政务",
    "合同",
    "商业合同审阅"
  ],
  "description": "逐条提取合同义务、识别风险和缺失保护，并形成可谈判的优先清单",
  "search_keywords": [
    "合同审阅",
    "风险条款",
    "义务清单",
    "谈判建议",
    "NDA",
    "SaaS合同"
  ],
  "supported_platforms": [
    "Claude",
    "Codex",
    "GPT",
    "Manus",
    "Trae",
    "Qorder"
  ],
  "inputs": {
    "required": [
      "contract_text_or_file",
      "reviewing_party"
    ],
    "optional": [
      "jurisdiction",
      "transaction_context",
      "risk_tolerance",
      "negotiation_position"
    ]
  },
  "outputs": [
    "contract_risk_register.md",
    "obligation_register.md",
    "negotiation_priorities.md"
  ],
  "implementation": {
    "readme": "README.md",
    "entry_doc": "SKILL.md",
    "invocation_doc": "INVOCATION.md",
    "script": "",
    "config": "",
    "base_prompt": "BASE_PROMPT.md",
    "examples_dir": "examples",
    "eval_dir": "eval",
    "platform_adapters_dir": "platforms"
  },
  "constraints": [
    "不替代有执照律师的正式法律意见",
    "不虚构管辖法律、市场惯例或可执行性",
    "不把建议措辞描述成已获法律确认"
  ],
  "distribution": {
    "share_as_single_folder": true,
    "required_files": [
      "SKILL.md",
      "skill.json",
      "README.md",
      "INVOCATION.md",
      "BASE_PROMPT.md"
    ],
    "package_files": [
      "BASE_PROMPT.md",
      "INVOCATION.md",
      "README.md",
      "SKILL.md",
      "agents/openai.yaml",
      "assets/decision-record-template.md",
      "assets/risk-register-template.md",
      "eval/acceptance.md",
      "examples/README.md",
      "platforms/README.md",
      "references/compliance-baseline.md",
      "references/review-matrix.md",
      "references/scenario-playbook.md",
      "skill.json"
    ]
  },
  "compliance": {
    "profile": "legal",
    "baseline": "references/compliance-baseline.md",
    "decision_states": [
      "ALLOW",
      "REVIEW_REQUIRED",
      "COMPLIANCE_REJECTED"
    ],
    "human_review_required_when_uncertain": true,
    "does_not_replace_system_controls_or_professional_advice": true
  }
}
