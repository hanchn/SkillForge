{
  "name": "eu-market-regulatory-compliance-counsel",
  "display_name": "欧盟市场合规顾问",
  "type": "portable-business-skill",
  "scope": "cross-platform",
  "version": "1.0.5",
  "owner_project": "SkillForge",
  "portable": true,
  "entrypoint": "SKILL.md",
  "category_path": [
    "法律政务",
    "欧盟合规"
  ],
  "description": "按产品法规、经济运营商、成员国、销售渠道和数据流识别欧盟市场准入与持续合规责任。适用于产品进入欧盟市场、欧盟责任人、进口商和平台责任审查、CE、GPSR、标签、VAT、隐私和召回流程审查，交付欧盟法规与角色责任地图、技术文件、标签和线上展示证据清单、缺口、整改、监控和欧盟专业升级方案。",
  "search_keywords": [
    "产品进入欧盟市场",
    "欧盟责任人、进口商和平台责任审查",
    "CE、GPSR、标签、VAT、隐私和召回流程审查",
    "制造商、进口商、授权代表和责任人",
    "GPSR、CE 与产品专项法规路由",
    "风险评估、技术文件、测试和追溯"
  ],
  "supported_platforms": [
    "Claude",
    "Codex",
    "GPT",
    "Manus",
    "Trae",
    "Qorder"
  ],
  "inputs": {
    "required": [
      "业务目标、范围和现状证据"
    ],
    "optional": [
      "历史数据、流程系统资料、目标、预算、SLA 和合规约束"
    ]
  },
  "outputs": [
    "欧盟法规与角色责任地图",
    "技术文件、标签和线上展示证据清单",
    "缺口、整改、监控和欧盟专业升级方案",
    "决策、执行、验收、风险和未知项记录"
  ],
  "implementation": {
    "readme": "README.md",
    "entry_doc": "SKILL.md",
    "invocation_doc": "INVOCATION.md",
    "script": "",
    "config": "",
    "base_prompt": "BASE_PROMPT.md",
    "examples_dir": "examples",
    "eval_dir": "eval",
    "platform_adapters_dir": "platforms"
  },
  "constraints": [
    "不得以 CE 标识或单份测试报告替代完整合规评估；必须确认适用法规、经济运营商和成员国要求的当前版本。",
    "不得虚构事实、数据、权限、实施或验证结果",
    "必须明确口径、责任、验收、风险和未知项"
  ],
  "distribution": {
    "share_as_single_folder": true,
    "required_files": [
      "SKILL.md",
      "skill.json",
      "README.md",
      "INVOCATION.md",
      "BASE_PROMPT.md"
    ],
    "package_files": [
      "BASE_PROMPT.md",
      "INVOCATION.md",
      "README.md",
      "SKILL.md",
      "agents/openai.yaml",
      "assets/data-source-intake-template.md",
      "assets/decision-record-template.md",
      "assets/delivery-template.md",
      "eval/acceptance.md",
      "examples/README.md",
      "platforms/README.md",
      "references/compliance-baseline.md",
      "references/data-source-and-api-gate.md",
      "references/professional-checklist.md",
      "references/scenario-playbook.md",
      "skill.json"
    ]
  },
  "compliance": {
    "profile": "legal",
    "baseline": "references/compliance-baseline.md",
    "decision_states": [
      "ALLOW",
      "REVIEW_REQUIRED",
      "COMPLIANCE_REJECTED"
    ],
    "human_review_required_when_uncertain": true,
    "does_not_replace_system_controls_or_professional_advice": true
  }
}
