{
  "name": "advertising-claims-legal-reviewer",
  "display_name": "广告声明法律审查师",
  "type": "portable-business-skill",
  "scope": "cross-platform",
  "version": "1.0.1",
  "owner_project": "SkillForge",
  "portable": true,
  "entrypoint": "SKILL.md",
  "category_path": [
    "法律政务",
    "广告与消费者保护"
  ],
  "description": "审查产品声明、比较广告、折扣、评价、达人背书、环保和健康表达的证据与披露。适用于Listing、落地页和广告上线前审查、达人、评价和促销机制、高风险产品声明整改，交付声明逐条证据矩阵、风险等级与修改稿、披露、审批和留档要求。",
  "search_keywords": [
    "Listing、落地页和广告上线前审查",
    "达人、评价和促销机制",
    "高风险产品声明整改",
    "明示和暗示声明",
    "可靠证据与适用人群",
    "达人关系和显著披露"
  ],
  "supported_platforms": [
    "Claude",
    "Codex",
    "GPT",
    "Manus",
    "Trae",
    "Qorder"
  ],
  "inputs": {
    "required": [
      "业务目标、范围和现状证据"
    ],
    "optional": [
      "历史数据、流程系统资料、目标、预算、SLA 和合规约束"
    ]
  },
  "outputs": [
    "声明逐条证据矩阵",
    "风险等级与修改稿",
    "披露、审批和留档要求",
    "决策、执行、验收、风险和未知项记录"
  ],
  "implementation": {
    "readme": "README.md",
    "entry_doc": "SKILL.md",
    "invocation_doc": "INVOCATION.md",
    "script": "",
    "config": "",
    "base_prompt": "BASE_PROMPT.md",
    "examples_dir": "examples",
    "eval_dir": "eval",
    "platform_adapters_dir": "platforms"
  },
  "constraints": [
    "不得用免责声明修复核心误导，也不得批准缺少可靠证据的客观声明。",
    "不得虚构事实、数据、权限、实施或验证结果",
    "必须明确口径、责任、验收、风险和未知项"
  ],
  "distribution": {
    "share_as_single_folder": true,
    "required_files": [
      "SKILL.md",
      "skill.json",
      "README.md",
      "INVOCATION.md",
      "BASE_PROMPT.md"
    ],
    "package_files": [
      "BASE_PROMPT.md",
      "INVOCATION.md",
      "README.md",
      "SKILL.md",
      "agents/openai.yaml",
      "assets/delivery-template.md",
      "eval/acceptance.md",
      "examples/README.md",
      "platforms/README.md",
      "references/compliance-baseline.md",
      "references/professional-checklist.md",
      "skill.json"
    ]
  },
  "compliance": {
    "profile": "legal",
    "baseline": "references/compliance-baseline.md",
    "decision_states": [
      "ALLOW",
      "REVIEW_REQUIRED",
      "COMPLIANCE_REJECTED"
    ],
    "human_review_required_when_uncertain": true,
    "does_not_replace_system_controls_or_professional_advice": true
  }
}
