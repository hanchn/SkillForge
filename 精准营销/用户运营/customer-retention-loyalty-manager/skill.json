{
  "name": "customer-retention-loyalty-manager",
  "display_name": "用户生命周期、会员与挽留经理",
  "type": "portable-business-skill",
  "scope": "cross-platform",
  "version": "1.0.6",
  "owner_project": "SkillForge",
  "portable": true,
  "entrypoint": "SKILL.md",
  "category_path": [
    "精准营销",
    "用户运营"
  ],
  "description": "基于统一客户身份、同意、客户价值和行为周期，设计新客培育、老客复购、会员权益、流失预警、召回挽留和忠诚增长闭环。适用于新客首购后培育与二购提升、新老客分层、生命周期旅程和老客经营、会员、等级、积分、权益和推荐计划、沉默、流失预警、召回与挽留、留存下降、会员成本或复购质量诊断，交付新客、老客、会员和流失定义及数据质量报告、生命周期分层、状态机、触发、频控和跨渠道旅程、会员权益、积分负债、成本、毛利和体验模型、召回挽留实验、增量评估、止损与复盘。",
  "search_keywords": [
    "新客首购后培育与二购提升",
    "新老客分层、生命周期旅程和老客经营",
    "会员、等级、积分、权益和推荐计划",
    "沉默、流失预警、召回与挽留",
    "留存下降、会员成本或复购质量诊断",
    "客户身份、同意、新老客和会员口径",
    "cohort、RFM、LTV、复购周期和成熟度",
    "激活、首购、二购、活跃、沉默、流失和召回状态"
  ],
  "supported_platforms": [
    "Claude",
    "Codex",
    "GPT",
    "Manus",
    "Trae",
    "Qorder"
  ],
  "inputs": {
    "required": [
      "业务目标、范围和现状证据"
    ],
    "optional": [
      "历史数据、流程系统资料、目标、预算、SLA 和合规约束"
    ]
  },
  "outputs": [
    "新客、老客、会员和流失定义及数据质量报告",
    "生命周期分层、状态机、触发、频控和跨渠道旅程",
    "会员权益、积分负债、成本、毛利和体验模型",
    "召回挽留实验、增量评估、止损与复盘",
    "决策、执行、验收、风险和未知项记录"
  ],
  "implementation": {
    "readme": "README.md",
    "entry_doc": "SKILL.md",
    "invocation_doc": "INVOCATION.md",
    "script": "",
    "config": "",
    "base_prompt": "BASE_PROMPT.md",
    "examples_dir": "examples",
    "eval_dir": "eval",
    "platform_adapters_dir": "platforms"
  },
  "constraints": [
    "不得把不同身份误合并，不得用敏感属性或未经同意数据分层；不得用无差别优惠、骚扰触达或把自然回流计为挽留增量，自动流失评分必须可解释并允许人工干预。",
    "不得虚构事实、数据、权限、实施或验证结果",
    "必须明确口径、责任、验收、风险和未知项"
  ],
