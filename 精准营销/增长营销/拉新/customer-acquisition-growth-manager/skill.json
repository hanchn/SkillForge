{
  "name": "customer-acquisition-growth-manager",
  "display_name": "新客获取与拉新增长经理",
  "type": "portable-business-skill",
  "scope": "cross-platform",
  "version": "1.0.1",
  "owner_project": "SkillForge",
  "portable": true,
  "entrypoint": "SKILL.md",
  "category_path": [
    "精准营销",
    "增长营销",
    "拉新"
  ],
  "description": "围绕目标人群、获客渠道、首购路径和回收期设计可验证的新客增长系统。适用于新品或新市场拉新、付费、自然、达人和推荐获客组合、获客成本上升或新客质量下降诊断，交付新客增长模型与渠道组合、首触达到首购漏斗方案、预算、实验、回收期和止损计划。",
  "search_keywords": [
    "新品或新市场拉新",
    "付费、自然、达人和推荐获客组合",
    "获客成本上升或新客质量下降诊断",
    "新客定义、排除和去重",
    "人群、需求和渠道任务",
    "创意、落地页和首购转化"
  ],
  "supported_platforms": [
    "Claude",
    "Codex",
    "GPT",
    "Manus",
    "Trae",
    "Qorder"
  ],
  "inputs": {
    "required": [
      "业务目标、范围和现状证据"
    ],
    "optional": [
      "历史数据、流程系统资料、目标、预算、SLA 和合规约束"
    ]
  },
  "outputs": [
    "新客增长模型与渠道组合",
    "首触达到首购漏斗方案",
    "预算、实验、回收期和止损计划",
    "决策、执行、验收、风险和未知项记录"
  ],
  "implementation": {
    "readme": "README.md",
    "entry_doc": "SKILL.md",
    "invocation_doc": "INVOCATION.md",
    "script": "",
    "config": "",
    "base_prompt": "BASE_PROMPT.md",
    "examples_dir": "examples",
    "eval_dir": "eval",
    "platform_adapters_dir": "platforms"
  },
  "constraints": [
    "不得把所有订单或平台新客直接视为增量新客，也不得用不可持续折扣和无回收期投放制造表面拉新。",
    "不得虚构事实、数据、权限、实施或验证结果",
    "必须明确口径、责任、验收、风险和未知项"
  ],
  "distribution": {
    "share_as_single_folder": true,
    "required_files": [
      "SKILL.md",
      "skill.json",
      "README.md",
      "INVOCATION.md",
      "BASE_PROMPT.md"
    ],
    "package_files": [
      "BASE_PROMPT.md",
      "INVOCATION.md",
      "README.md",
      "SKILL.md",
      "agents/openai.yaml",
      "assets/delivery-template.md",
      "eval/acceptance.md",
      "examples/README.md",
      "platforms/README.md",
      "references/compliance-baseline.md",
      "references/professional-checklist.md",
      "skill.json"
    ]
  },
  "compliance": {
    "profile": "precision-marketing",
    "baseline": "references/compliance-baseline.md",
    "decision_states": [
      "ALLOW",
      "REVIEW_REQUIRED",
      "COMPLIANCE_REJECTED"
    ],
    "human_review_required_when_uncertain": true,
    "does_not_replace_system_controls_or_professional_advice": true
  }
}
