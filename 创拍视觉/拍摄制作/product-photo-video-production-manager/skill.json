{
  "name": "product-photo-video-production-manager",
  "display_name": "商品图片与视频拍摄制作经理",
  "type": "portable-business-skill",
  "scope": "cross-platform",
  "version": "1.0.2",
  "owner_project": "SkillForge",
  "portable": true,
  "entrypoint": "SKILL.md",
  "category_path": [
    "创拍视觉",
    "拍摄制作"
  ],
  "description": "把营销目标、商品事实和渠道规范转化为可执行的图片与视频拍摄、后期、验收和交付计划。适用于商品主图、场景图和视频拍摄、广告、社媒、达人和独立站素材制作、跨市场拍摄重制与批量交付，交付拍摄策略、shot list 和脚本、人员、场地、样品、预算与排期、后期、合规、质检和交付清单。",
  "search_keywords": [
    "商品主图、场景图和视频拍摄",
    "广告、社媒、达人和独立站素材制作",
    "跨市场拍摄重制与批量交付",
    "受众、卖点和证据镜头",
    "主图、细节、场景、UGC 和短视频格式",
    "样品、模特、场地、灯光和收音"
  ],
  "supported_platforms": [
    "Claude",
    "Codex",
    "GPT",
    "Manus",
    "Trae",
    "Qorder"
  ],
  "inputs": {
    "required": [
      "业务目标、范围和现状证据"
    ],
    "optional": [
      "历史数据、流程系统资料、目标、预算、SLA 和合规约束"
    ]
  },
  "outputs": [
    "拍摄策略、shot list 和脚本",
    "人员、场地、样品、预算与排期",
    "后期、合规、质检和交付清单",
    "决策、执行、验收、风险和未知项记录"
  ],
  "implementation": {
    "readme": "README.md",
    "entry_doc": "SKILL.md",
    "invocation_doc": "INVOCATION.md",
    "script": "",
    "config": "",
    "base_prompt": "BASE_PROMPT.md",
    "examples_dir": "examples",
    "eval_dir": "eval",
    "platform_adapters_dir": "platforms"
  },
  "constraints": [
    "不得通过后期改变产品关键事实、尺寸、颜色或效果；模特、场地、音乐、字体和用户内容必须有明确授权范围。",
    "不得虚构事实、数据、权限、实施或验证结果",
    "必须明确口径、责任、验收、风险和未知项"
  ],
  "distribution": {
    "share_as_single_folder": true,
    "required_files": [
      "SKILL.md",
      "skill.json",
      "README.md",
      "INVOCATION.md",
      "BASE_PROMPT.md"
    ],
    "package_files": [
      "BASE_PROMPT.md",
      "INVOCATION.md",
      "README.md",
      "SKILL.md",
      "agents/openai.yaml",
      "assets/delivery-template.md",
      "eval/acceptance.md",
      "examples/README.md",
      "platforms/README.md",
      "references/compliance-baseline.md",
      "references/professional-checklist.md",
      "skill.json"
    ]
  },
  "compliance": {
    "profile": "creative-production",
    "baseline": "references/compliance-baseline.md",
    "decision_states": [
      "ALLOW",
      "REVIEW_REQUIRED",
      "COMPLIANCE_REJECTED"
    ],
    "human_review_required_when_uncertain": true,
    "does_not_replace_system_controls_or_professional_advice": true
  }
}
