{
  "name": "creative-asset-intelligent-tagging-specialist",
  "display_name": "创意素材智能打标专家",
  "type": "portable-business-skill",
  "scope": "cross-platform",
  "version": "1.0.1",
  "owner_project": "SkillForge",
