{
  "name": "ai-creative-authenticity-compliance-reviewer",
  "display_name": "AI 创意真实性与合规审查师",
  "type": "portable-business-skill",
  "scope": "cross-platform",
  "version": "1.0.3",
  "owner_project": "SkillForge",
  "portable": true,
  "entrypoint": "SKILL.md",
  "category_path": [
    "创拍视觉",
    "AI创意制作",
    "真实性合规"
  ],
  "description": "审查 AI 生成、替换、扩展和智能剪辑内容的商品真实性、人物权利、版权、披露、平台和证据要求。适用于AI 商品图视频上线前审查、虚拟模特和数字人风险检查、AI 素材来源、修改和披露审计，交付AI 创意逐项审查表、失真、权利和平台风险分级、修改、披露、留档和禁止上线清单。",
  "search_keywords": [
    "AI 商品图视频上线前审查",
    "虚拟模特和数字人风险检查",
    "AI 素材来源、修改和披露审计",
    "商品事实与生成差异",
    "人像、声音、肖像和深度合成",
    "版权、商标、字体和训练来源"
  ],
  "supported_platforms": [
    "Claude",
    "Codex",
    "GPT",
    "Manus",
    "Trae",
    "Qorder"
  ],
  "inputs": {
    "required": [
      "业务目标、范围和现状证据"
    ],
    "optional": [
      "历史数据、流程系统资料、目标、预算、SLA 和合规约束"
    ]
  },
  "outputs": [
    "AI 创意逐项审查表",
    "失真、权利和平台风险分级",
    "修改、披露、留档和禁止上线清单",
    "决策、执行、验收、风险和未知项记录"
  ],
  "implementation": {
    "readme": "README.md",
    "entry_doc": "SKILL.md",
    "invocation_doc": "INVOCATION.md",
    "script": "",
    "config": "",
    "base_prompt": "BASE_PROMPT.md",
    "examples_dir": "examples",
    "eval_dir": "eval",
    "platform_adapters_dir": "platforms"
  },
  "constraints": [
    "不得仅凭视觉自然就认定合规；无法证明商品真实性、人物授权、版权来源或必要披露的内容必须暂停上线并升级法务或平台合规人员。",
    "不得虚构事实、数据、权限、实施或验证结果",
    "必须明确口径、责任、验收、风险和未知项"
  ],
  "distribution": {
    "share_as_single_folder": true,
    "required_files": [
      "SKILL.md",
      "skill.json",
      "README.md",
      "INVOCATION.md",
      "BASE_PROMPT.md"
    ],
    "package_files": [
      "BASE_PROMPT.md",
      "INVOCATION.md",
      "README.md",
      "SKILL.md",
      "agents/openai.yaml",
      "assets/decision-record-template.md",
      "assets/delivery-template.md",
      "eval/acceptance.md",
      "examples/README.md",
      "platforms/README.md",
      "references/compliance-baseline.md",
      "references/professional-checklist.md",
      "references/scenario-playbook.md",
      "skill.json"
    ]
  },
  "compliance": {
    "profile": "creative-production",
    "baseline": "references/compliance-baseline.md",
    "decision_states": [
      "ALLOW",
      "REVIEW_REQUIRED",
      "COMPLIANCE_REJECTED"
    ],
    "human_review_required_when_uncertain": true,
    "does_not_replace_system_controls_or_professional_advice": true
  }
}
