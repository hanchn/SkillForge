{
  "name": "shooting-production-coordinator",
  "display_name": "拍摄制片与现场统筹",
  "type": "portable-business-skill",
  "scope": "cross-platform",
  "version": "1.0.6",
  "owner_project": "SkillForge",
  "portable": true,
  "entrypoint": "SKILL.md",
  "category_path": [
    "创拍视觉",
    "拍摄统筹"
  ],
  "description": "把创意方案转化为预算、排期、样品、人员、场地、设备、通告和现场执行计划。适用于棚拍或外景拍摄筹备、多 SKU 批量拍摄、跨团队拍摄进度和成本治理，交付制作预算与排期、人员、样品、场地和设备清单、通告单、现场流程和异常预案。",
  "search_keywords": [
    "棚拍或外景拍摄筹备",
    "多 SKU 批量拍摄",
    "跨团队拍摄进度和成本治理",
    "brief、shot list 和优先级",
    "样品状态、道具和物流",
    "摄影、导演、模特和供应商"
  ],
  "supported_platforms": [
    "Claude",
    "Codex",
    "GPT",
    "Manus",
    "Trae",
    "Qorder"
  ],
  "inputs": {
    "required": [
      "业务目标、范围和现状证据"
    ],
    "optional": [
      "历史数据、流程系统资料、目标、预算、SLA 和合规约束"
    ]
  },
  "outputs": [
    "制作预算与排期",
    "人员、样品、场地和设备清单",
    "通告单、现场流程和异常预案",
    "决策、执行、验收、风险和未知项记录"
  ],
  "implementation": {
    "readme": "README.md",
    "entry_doc": "SKILL.md",
    "invocation_doc": "INVOCATION.md",
    "script": "",
    "config": "",
    "base_prompt": "BASE_PROMPT.md",
    "examples_dir": "examples",
    "eval_dir": "eval",
    "platform_adapters_dir": "platforms"
  },
  "constraints": [
    "不得在缺少场地、肖像、未成年人、安全或商业使用授权时开拍；现场变更必须记录对预算、范围和交付的影响。",
    "不得虚构事实、数据、权限、实施或验证结果",
    "必须明确口径、责任、验收、风险和未知项"
  ],
  "distribution": {
    "share_as_single_folder": true,
    "required_files": [
      "SKILL.md",
      "skill.json",
      "README.md",
      "INVOCATION.md",
      "BASE_PROMPT.md"
    ],
    "package_files": [
      "BASE_PROMPT.md",
      "INVOCATION.md",
      "README.md",
      "SKILL.md",
      "agents/openai.yaml",
      "assets/data-source-intake-template.md",
      "assets/decision-record-template.md",
      "assets/delivery-template.md",
      "eval/acceptance.md",
      "examples/README.md",
      "platforms/README.md",
      "references/compliance-baseline.md",
      "references/data-source-and-api-gate.md",
      "references/professional-checklist.md",
      "references/scenario-playbook.md",
      "skill.json"
    ]
  },
  "compliance": {
    "profile": "creative-production",
    "baseline": "references/compliance-baseline.md",
    "decision_states": [
      "ALLOW",
      "REVIEW_REQUIRED",
      "COMPLIANCE_REJECTED"
    ],
    "human_review_required_when_uncertain": true,
    "does_not_replace_system_controls_or_professional_advice": true
  }
}
