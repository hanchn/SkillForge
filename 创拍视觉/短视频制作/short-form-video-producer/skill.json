{
  "name": "short-form-video-producer",
  "display_name": "跨境短视频制作导演",
  "type": "portable-business-skill",
  "scope": "cross-platform",
  "version": "1.0.6",
  "owner_project": "SkillForge",
  "portable": true,
  "entrypoint": "SKILL.md",
  "category_path": [
    "创拍视觉",
    "短视频制作"
  ],
  "description": "面向广告、TikTok、Reels、Shorts 和商品页设计高密度、平台原生、可测试的短视频。适用于商品广告短视频、社媒竖屏内容、功能演示、场景故事和口播制作，交付视频角度与脚本矩阵、分镜、镜头、字幕和声音方案、版本测试、平台规格和验收清单。",
  "search_keywords": [
    "商品广告短视频",
    "社媒竖屏内容",
    "功能演示、场景故事和口播制作",
    "首秒钩子和目标人群",
    "问题、证据、演示和 CTA",
    "9:16 构图、节奏和安全区"
  ],
  "supported_platforms": [
    "Claude",
    "Codex",
    "GPT",
    "Manus",
    "Trae",
    "Qorder"
  ],
  "inputs": {
    "required": [
      "业务目标、范围和现状证据"
    ],
    "optional": [
      "历史数据、流程系统资料、目标、预算、SLA 和合规约束"
    ]
  },
  "outputs": [
    "视频角度与脚本矩阵",
    "分镜、镜头、字幕和声音方案",
    "版本测试、平台规格和验收清单",
    "决策、执行、验收、风险和未知项记录"
  ],
  "implementation": {
    "readme": "README.md",
    "entry_doc": "SKILL.md",
    "invocation_doc": "INVOCATION.md",
    "script": "",
    "config": "",
    "base_prompt": "BASE_PROMPT.md",
    "examples_dir": "examples",
    "eval_dir": "eval",
    "platform_adapters_dir": "platforms"
  },
  "constraints": [
    "不得伪造演示、评价或前后对比；音乐、字体、素材和人物必须具备对应平台、地域、期限和商业用途授权。",
    "不得虚构事实、数据、权限、实施或验证结果",
    "必须明确口径、责任、验收、风险和未知项"
  ],
  "distribution": {
    "share_as_single_folder": true,
    "required_files": [
      "SKILL.md",
      "skill.json",
      "README.md",
      "INVOCATION.md",
      "BASE_PROMPT.md"
    ],
    "package_files": [
      "BASE_PROMPT.md",
      "INVOCATION.md",
      "README.md",
      "SKILL.md",
      "agents/openai.yaml",
      "assets/data-source-intake-template.md",
      "assets/decision-record-template.md",
      "assets/delivery-template.md",
      "eval/acceptance.md",
      "examples/README.md",
      "platforms/README.md",
      "references/compliance-baseline.md",
      "references/data-source-and-api-gate.md",
      "references/professional-checklist.md",
      "references/scenario-playbook.md",
      "skill.json"
    ]
  },
  "compliance": {
    "profile": "creative-production",
    "baseline": "references/compliance-baseline.md",
    "decision_states": [
      "ALLOW",
      "REVIEW_REQUIRED",
      "COMPLIANCE_REJECTED"
