{
  "name": "retrospective-action-closure-facilitator",
  "display_name": "复盘与行动闭环主持专家",
  "type": "portable-business-skill",
  "scope": "cross-platform",
  "version": "1.0.0",
  "owner_project": "SkillForge",
  "portable": true,
  "entrypoint": "SKILL.md",
  "category_path": [
    "基础工具",
    "汇报复盘"
  ],
  "description": "基于事件、项目、活动或经营周期证据组织无责复盘，区分时间线、事实、促成条件和根因，并追踪行动到效果验证。适用于事故与异常复盘、项目、发布或活动复盘、月度季度经营复盘与重复问题治理，交付证据化复盘报告、促成因素、根因和系统性改进、行动、owner、验证、关闭与复发监控台账。",
  "search_keywords": [
    "事故与异常复盘",
    "项目、发布或活动复盘",
    "月度季度经营复盘与重复问题治理",
    "目标、范围和复盘类型",
    "事实时间线、数据和决策上下文",
    "直接原因、促成条件和控制缺口"
  ],
  "supported_platforms": [
    "Claude",
    "Codex",
    "GPT",
    "Manus",
    "Trae",
    "Qorder"
  ],
  "inputs": {
    "required": [
      "业务目标、范围和现状证据"
    ],
    "optional": [
      "历史数据、流程系统资料、目标、预算、SLA 和合规约束"
    ]
  },
  "outputs": [
    "证据化复盘报告",
    "促成因素、根因和系统性改进",
    "行动、owner、验证、关闭与复发监控台账",
    "决策、执行、验收、风险和未知项记录"
  ],
  "implementation": {
    "readme": "README.md",
    "entry_doc": "SKILL.md",
    "invocation_doc": "INVOCATION.md",
    "script": "",
    "config": "",
    "base_prompt": "BASE_PROMPT.md",
    "examples_dir": "examples",
    "eval_dir": "eval",
    "platform_adapters_dir": "platforms"
  },
  "constraints": [
    "不得在证据不足时追责个人或宣称唯一根因；行动未验证效果时不得仅因完成任务而关闭问题。",
    "不得虚构事实、数据、权限、实施或验证结果",
    "必须明确口径、责任、验收、风险和未知项"
  ],
  "distribution": {
    "share_as_single_folder": true,
    "required_files": [
      "SKILL.md",
      "skill.json",
      "README.md",
      "INVOCATION.md",
      "BASE_PROMPT.md"
    ],
    "package_files": [
      "BASE_PROMPT.md",
      "INVOCATION.md",
      "README.md",
      "SKILL.md",
      "agents/openai.yaml",
      "assets/data-source-intake-template.md",
      "assets/decision-record-template.md",
      "assets/delivery-template.md",
      "eval/acceptance.md",
      "examples/README.md",
      "platforms/README.md",
      "references/compliance-baseline.md",
      "references/data-source-and-api-gate.md",
      "references/professional-checklist.md",
      "references/scenario-playbook.md",
      "skill.json"
    ]
  },
  "compliance": {
    "profile": "foundation-tools",
    "baseline": "references/compliance-baseline.md",
    "decision_states": [
      "ALLOW",
      "REVIEW_REQUIRED",
      "COMPLIANCE_REJECTED"
    ],
    "human_review_required_when_uncertain": true,
    "does_not_replace_system_controls_or_professional_advice": true
  }
}
