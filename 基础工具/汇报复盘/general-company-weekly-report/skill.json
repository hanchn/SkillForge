{
  "name": "general-company-weekly-report",
  "display_name": "企业通用周报",
  "type": "portable-business-skill",
  "scope": "cross-platform",
  "version": "1.0.0",
  "owner_project": "SkillForge",
  "portable": true,
  "entrypoint": "SKILL.md",
  "category_path": [
    "基础工具",
    "汇报复盘"
  ],
  "description": "把一个团队或跨部门周期内的真实数据、交付、风险、决策和下周承诺整理成可核验周报，同时保留业务角色专属口径。适用于缺少专属角色 Skill 的团队周报、跨部门项目周报、管理层通用进展与风险汇报，交付结论先行周报、数据证据与状态对照表、风险、决策、依赖和下周验收计划。",
  "search_keywords": [
    "缺少专属角色 Skill 的团队周报",
    "跨部门项目周报",
    "管理层通用进展与风险汇报",
    "本周与上周/目标的比较口径",
    "业务结果与交付证据",
    "完成、进行中、阻塞和取消状态"
  ],
  "supported_platforms": [
    "Claude",
    "Codex",
    "GPT",
    "Manus",
    "Trae",
    "Qorder"
  ],
  "inputs": {
    "required": [
      "业务目标、范围和现状证据"
    ],
    "optional": [
      "历史数据、流程系统资料、目标、预算、SLA 和合规约束"
    ]
  },
  "outputs": [
    "结论先行周报",
    "数据证据与状态对照表",
    "风险、决策、依赖和下周验收计划",
    "决策、执行、验收、风险和未知项记录"
  ],
  "implementation": {
    "readme": "README.md",
    "entry_doc": "SKILL.md",
    "invocation_doc": "INVOCATION.md",
    "script": "",
    "config": "",
    "base_prompt": "BASE_PROMPT.md",
    "examples_dir": "examples",
    "eval_dir": "eval",
    "platform_adapters_dir": "platforms"
  },
  "constraints": [
    "不得用通用周报替代已有角色专属周报，不得把活动数量写成业务结果或编造未提供的数据与完成状态。",
    "不得虚构事实、数据、权限、实施或验证结果",
    "必须明确口径、责任、验收、风险和未知项"
  ],
  "distribution": {
    "share_as_single_folder": true,
    "required_files": [
      "SKILL.md",
      "skill.json",
      "README.md",
      "INVOCATION.md",
      "BASE_PROMPT.md"
    ],
    "package_files": [
      "BASE_PROMPT.md",
      "INVOCATION.md",
      "README.md",
      "SKILL.md",
      "agents/openai.yaml",
      "assets/data-source-intake-template.md",
      "assets/decision-record-template.md",
      "assets/delivery-template.md",
      "eval/acceptance.md",
      "examples/README.md",
      "platforms/README.md",
      "references/compliance-baseline.md",
      "references/data-source-and-api-gate.md",
      "references/professional-checklist.md",
      "references/scenario-playbook.md",
      "skill.json"
    ]
  },
  "compliance": {
    "profile": "foundation-tools",
    "baseline": "references/compliance-baseline.md",
    "decision_states": [
      "ALLOW",
      "REVIEW_REQUIRED",
      "COMPLIANCE_REJECTED"
    ],
    "human_review_required_when_uncertain": true,
    "does_not_replace_system_controls_or_professional_advice": true
  }
}
