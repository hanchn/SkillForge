{
  "name": "customer-service-voice-manager",
  "display_name": "跨境多语言客服经理",
  "type": "portable-business-skill",
  "scope": "cross-platform",
  "version": "1.0.0",
  "owner_project": "SkillForge",
  "portable": true,
  "entrypoint": "SKILL.md",
  "category_path": [
    "跨境运营",
    "客户体验"
  ],
  "description": "以多语言一致性、问题解决和客户洞察运营售前售后服务。适用于邮件、在线聊天和平台消息客服、多语言话术体系、客服质检和 VOC 闭环，交付客服 SOP 与话术库、升级和赔付矩阵、VOC 分类与改进报告。",
  "search_keywords": [
    "邮件、在线聊天和平台消息客服",
    "多语言话术体系",
    "客服质检和 VOC 闭环",
    "语言、语气和文化",
    "意图识别和信息核验",
    "政策、权限和升级"
  ],
  "supported_platforms": [
    "Claude",
    "Codex",
    "GPT",
    "Manus",
    "Trae",
    "Qorder"
  ],
  "inputs": {
    "required": [
      "业务目标、范围和现状证据"
    ],
    "optional": [
      "历史数据、流程系统资料、目标、预算、SLA 和合规约束"
    ]
  },
  "outputs": [
    "客服 SOP 与话术库",
    "升级和赔付矩阵",
    "VOC 分类与改进报告",
    "决策、执行、验收、风险和未知项记录"
  ],
  "implementation": {
    "readme": "README.md",
    "entry_doc": "SKILL.md",
    "invocation_doc": "INVOCATION.md",
    "script": "",
    "config": "",
    "base_prompt": "BASE_PROMPT.md",
    "examples_dir": "examples",
    "eval_dir": "eval",
    "platform_adapters_dir": "platforms"
  },
  "constraints": [
    "不得承诺超出政策或权限的结果，也不得机械直译敏感回复。",
    "不得虚构事实、数据、权限、实施或验证结果",
    "必须明确口径、责任、验收、风险和未知项"
  ],
  "distribution": {
    "share_as_single_folder": true,
    "required_files": [
      "SKILL.md",
      "skill.json",
      "README.md",
      "INVOCATION.md",
      "BASE_PROMPT.md"
    ],
    "package_files": [
      "SKILL.md",
      "skill.json",
      "README.md",
      "INVOCATION.md",
      "BASE_PROMPT.md",
      "agents/openai.yaml",
      "references",
      "assets",
      "examples",
      "eval",
      "platforms"
    ]
  }
}
