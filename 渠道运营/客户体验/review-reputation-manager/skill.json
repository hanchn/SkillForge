{
  "name": "review-reputation-manager",
  "display_name": "评价分析与品牌声誉经理",
  "type": "portable-business-skill",
  "scope": "cross-platform",
  "version": "1.0.6",
  "owner_project": "SkillForge",
  "portable": true,
  "entrypoint": "SKILL.md",
  "category_path": [
    "渠道运营",
    "客户体验"
  ],
  "description": "基于授权评价原文、星级、SKU、站点、时间及订单、退货、客服和 VOC 数据，合规分析主题、趋势、异常与根因，并推动产品、页面、履约和服务改进。适用于跨平台评价批量分析、差评、评分波动和异常评价诊断、评价主题与退货、客服、商品和履约联合分析、公开回复、升级和改进效果复盘，交付评价数据质量与健康报告、主题、情绪、严重度、趋势和异常分析、合规回复、根因、owner 和改进闭环、整改前后效果与剩余风险报告。",
  "search_keywords": [
    "跨平台评价批量分析",
    "差评、评分波动和异常评价诊断",
    "评价主题与退货、客服、商品和履约联合分析",
    "公开回复、升级和改进效果复盘",
    "评价来源、授权、真实性和样本偏差",
    "站点、语言、SKU/ASIN、星级和时间口径",
    "主题、情绪、严重度、置信度和证据原文"
  ],
  "supported_platforms": [
    "Claude",
    "Codex",
    "GPT",
    "Manus",
    "Trae",
    "Qorder"
  ],
  "inputs": {
    "required": [
      "业务目标、范围和现状证据"
    ],
    "optional": [
      "历史数据、流程系统资料、目标、预算、SLA 和合规约束"
    ]
  },
  "outputs": [
    "评价数据质量与健康报告",
    "主题、情绪、严重度、趋势和异常分析",
    "合规回复、根因、owner 和改进闭环",
    "整改前后效果与剩余风险报告",
    "决策、执行、验收、风险和未知项记录"
  ],
  "implementation": {
    "readme": "README.md",
    "entry_doc": "SKILL.md",
    "invocation_doc": "INVOCATION.md",
    "script": "",
    "config": "",
    "base_prompt": "BASE_PROMPT.md",
    "examples_dir": "examples",
    "eval_dir": "eval",
    "platform_adapters_dir": "platforms"
  },
  "constraints": [
    "不得操纵评价、诱导只留好评、推断评价者敏感属性或披露客户隐私；情绪和主题模型必须抽检，异常只能标为待核验，不得自动认定虚假或恶意评价。",
    "不得虚构事实、数据、权限、实施或验证结果",
    "必须明确口径、责任、验收、风险和未知项"
  ],
  "distribution": {
    "share_as_single_folder": true,
    "required_files": [
      "SKILL.md",
      "skill.json",
      "README.md",
      "INVOCATION.md",
      "BASE_PROMPT.md"
    ],
    "package_files": [
      "BASE_PROMPT.md",
      "INVOCATION.md",
      "README.md",
      "SKILL.md",
      "agents/openai.yaml",
      "assets/data-source-intake-template.md",
      "assets/decision-record-template.md",
      "assets/delivery-template.md",
      "eval/acceptance.md",
      "examples/README.md",
      "platforms/README.md",
      "references/compliance-baseline.md",
      "references/data-source-and-api-gate.md",
      "references/professional-checklist.md",
      "references/scenario-playbook.md",
      "skill.json"
    ]
  },
  "compliance": {
    "profile": "channel-commerce",
    "baseline": "references/compliance-baseline.md",
    "decision_states": [
      "ALLOW",
      "REVIEW_REQUIRED",
      "COMPLIANCE_REJECTED"
    ],
    "human_review_required_when_uncertain": true,
    "does_not_replace_system_controls_or_professional_advice": true
  }
}
