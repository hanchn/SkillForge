  "supported_platforms": [
    "Claude",
    "Codex",
    "GPT",
    "Manus",
    "Trae",
    "Qorder"
  ],
  "inputs": {
    "required": [
      "产品与包装尺寸重量、起运和目的地"
    ],
    "optional": [
      "渠道需求、订单结构与服务承诺",
      "承运商、仓库、FBA/3PL 报价和限制"
    ]
  },
  "outputs": [
    "履约网络与运输方案",
    "完整成本和时效比较",
    "入仓/上线日历",
    "异常、切换与逆向物流方案"
  ],
  "implementation": {
    "readme": "README.md",
    "entry_doc": "SKILL.md",
    "invocation_doc": "INVOCATION.md",
    "script": "",
    "config": "",
    "base_prompt": "BASE_PROMPT.md",
    "examples_dir": "examples",
    "eval_dir": "eval",
    "platform_adapters_dir": "platforms"
  },
  "constraints": [
    "不得用基础运价代替完整落地与履约成本",
    "不得忽略体积重、旺季、偏远、燃油、仓储和退货费用",
    "不得承诺承运商无法保证的时效",
    "涉及海关、危险品和税务时必须使用当前专业规则并标记责任人"
