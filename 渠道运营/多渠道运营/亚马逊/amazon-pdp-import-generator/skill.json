{
  "name": "amazon-pdp-import-generator",
  "display_name": "亚马逊 PDP 导入草稿生成器",
  "type": "portable-business-skill",
  "scope": "cross-platform",
  "version": "2.0.1",
  "owner_project": "SkillForge",
  "portable": true,
  "entrypoint": "SKILL.md",
  "category_path": [
    "渠道运营",
    "多渠道运营",
    "亚马逊"
  ],
  "description": "从结构化图片文件名确定性生成 SKU、变体和图片分组草稿，再基于已验证商品事实生成亚马逊内容",
  "search_keywords": [
    "亚马逊",
    "PDP",
    "SKU",
    "变体",
    "图片分组",
    "CSV",
    "XLSX",
    "Listing"
  ],
  "supported_platforms": [
    "Claude",
    "Codex",
    "GPT",
    "Manus",
    "Trae",
    "Qorder"
  ],
  "inputs": {
    "required": [
      "image_folder_path"
    ],
    "optional": [
      "brand",
      "marketplace",
      "category",
      "variation_theme",
      "verified_product_facts"
    ]
  },
  "outputs": [
    "amazon_pdp_import_draft.xlsx",
    "amazon_pdp_import_draft.csv",
    "parse_log.csv",
    "review_summary.md"
  ],
  "implementation": {
    "readme": "README.md",
    "entry_doc": "SKILL.md",
    "invocation_doc": "INVOCATION.md",
    "script": "scripts/generate_pdp_import.py",
    "config": "assets/parser_config.json",
    "base_prompt": "BASE_PROMPT.md",
    "examples_dir": "examples",
    "eval_dir": "eval",
    "platform_adapters_dir": "platforms"
  },
  "constraints": [
    "不得从文件名或图片推断未经验证的商品声明",
    "不得把通用草稿称为已适配 Seller Central 的可上传模板",
    "目录为空或解析冲突时不得伪造结果"
  ],
  "distribution": {
    "share_as_single_folder": true,
    "required_files": [
      "SKILL.md",
      "skill.json",
      "README.md",
      "INVOCATION.md",
      "BASE_PROMPT.md"
    ],
    "package_files": [
      "BASE_PROMPT.md",
      "INVOCATION.md",
      "README.md",
      "SKILL.md",
      "agents/openai.yaml",
      "assets/content-guardrails.md",
      "assets/parser_config.json",
      "eval/acceptance.md",
      "examples/README.md",
      "examples/sample_input_files.txt",
      "examples/sample_output.csv",
      "platforms/claude.md",
      "platforms/codex.md",
      "platforms/gpt.md",
      "platforms/manus.md",
      "platforms/qorder.md",
      "platforms/trae.md",
      "references/compliance-baseline.md",
      "scripts/generate_pdp_import.py",
      "skill.json"
    ]
  },
  "compliance": {
    "profile": "channel-commerce",
    "baseline": "references/compliance-baseline.md",
    "decision_states": [
      "ALLOW",
      "REVIEW_REQUIRED",
      "COMPLIANCE_REJECTED"
    ],
    "human_review_required_when_uncertain": true,
    "does_not_replace_system_controls_or_professional_advice": true
  }
}
