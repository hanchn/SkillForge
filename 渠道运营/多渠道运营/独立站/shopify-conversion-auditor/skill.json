{
  "name": "shopify-conversion-auditor",
  "display_name": "Shopify 转化审计师",
  "type": "portable-business-skill",
  "scope": "cross-platform",
  "version": "1.0.2",
  "owner_project": "SkillForge",
  "portable": true,
  "entrypoint": "SKILL.md",
  "category_path": [
    "渠道运营",
    "多渠道运营",
    "独立站"
  ],
  "description": "基于页面、数据和真实商品事实审计 Shopify 转化障碍并排序改进项",
  "search_keywords": [
    "Shopify",
    "独立站",
    "CRO",
    "转化率",
    "商品页",
    "购物车",
    "结账"
  ],
  "supported_platforms": [
    "Claude",
    "Codex",
    "GPT",
    "Manus",
    "Trae",
    "Qorder"
  ],
  "inputs": {
    "required": [
      "store_evidence_or_url"
    ],
    "optional": [
      "analytics",
      "target_market",
      "traffic_mix",
      "theme_context"
    ]
  },
  "outputs": [
    "conversion_audit.md",
    "prioritized_backlog.md",
    "experiment_plan.md"
  ],
  "implementation": {
    "readme": "README.md",
    "entry_doc": "SKILL.md",
    "invocation_doc": "INVOCATION.md",
    "script": "",
    "config": "",
    "base_prompt": "BASE_PROMPT.md",
    "examples_dir": "examples",
    "eval_dir": "eval",
    "platform_adapters_dir": "platforms"
  },
  "constraints": [
    "不把审美偏好当转化证据",
    "不推荐虚假稀缺、伪造评价或隐藏费用",
    "不虚构促销、物流、退货、认证或商品事实"
  ],
  "distribution": {
    "share_as_single_folder": true,
    "required_files": [
      "SKILL.md",
      "skill.json",
      "README.md",
      "INVOCATION.md",
      "BASE_PROMPT.md"
    ],
    "package_files": [
      "BASE_PROMPT.md",
      "INVOCATION.md",
      "README.md",
      "SKILL.md",
      "agents/openai.yaml",
      "assets/audit-scorecard.md",
      "assets/decision-record-template.md",
      "eval/acceptance.md",
      "examples/README.md",
      "platforms/README.md",
      "references/audit-framework.md",
      "references/compliance-baseline.md",
      "references/scenario-playbook.md",
      "skill.json"
    ]
  },
  "compliance": {
    "profile": "channel-commerce",
    "baseline": "references/compliance-baseline.md",
    "decision_states": [
      "ALLOW",
      "REVIEW_REQUIRED",
      "COMPLIANCE_REJECTED"
    ],
    "human_review_required_when_uncertain": true,
    "does_not_replace_system_controls_or_professional_advice": true
  }
}
