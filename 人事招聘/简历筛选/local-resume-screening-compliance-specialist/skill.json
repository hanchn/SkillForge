{
  "name": "local-resume-screening-compliance-specialist",
  "display_name": "无人值守简历筛选与面试预约",
  "type": "portable-business-skill",
  "scope": "cross-platform",
  "version": "1.1.0",
  "owner_project": "SkillForge",
  "portable": true,
  "entrypoint": "SKILL.md",
  "category_path": ["人事招聘", "简历筛选"],
  "description": "读取 READY_FOR_HR 的 screening-spec.json，无人值守完成授权简历解析、岗位证据候选池、筛选漏斗和阈值预警，并通过招聘平台、日历、会议室和邮件 API 自动预约面试；异常统一发送飞书告警。",
  "search_keywords": [
    "无人值守简历筛选",
    "1000 份简历少于 10 人预警",
    "招聘平台 API 预约面试",
    "会议室和面试官通知",
    "候选人二次确认邮件",
    "飞书招聘异常告警"
  ],
  "supported_platforms": ["Claude", "Codex", "GPT", "Manus", "Trae", "Qorder"],
  "inputs": {
    "required": ["READY_FOR_HR 的 screening-spec.json、授权简历来源"],
    "optional": ["招聘平台、日历、会议室、邮件和飞书授权连接器、岗位历史漏斗"]
  },
  "outputs": [
    "岗位证据候选池",
    "筛选漏斗和异常归因",
    "面试预约、会议室、面试官和候选人确认状态",
    "飞书异常事件与回执",
    "最小审计记录"
  ],
  "implementation": {
    "readme": "README.md",
    "entry_doc": "SKILL.md",
    "invocation_doc": "INVOCATION.md",
    "script": "scripts/inventory_local_resumes.py",
    "config": "assets/screening-alert-policy.json",
    "base_prompt": "BASE_PROMPT.md",
    "examples_dir": "examples",
    "eval_dir": "eval",
    "platform_adapters_dir": "platforms"
  },
  "constraints": [
    "不得上传未授权简历、使用敏感属性排序或把关键词次数当作能力结论。",
    "不得重复创建会议，不得把 API 接受请求写成候选人已确认。",
    "自动化不得作为永久拒绝或最终录用的唯一依据。"
  ],
  "distribution": {
    "share_as_single_folder": true,
    "required_files": ["SKILL.md", "skill.json", "README.md", "INVOCATION.md", "BASE_PROMPT.md"],
    "package_files": [
      "BASE_PROMPT.md",
      "INVOCATION.md",
      "README.md",
      "SKILL.md",
      "agents/openai.yaml",
      "assets/candidate-review-card-template.md",
      "assets/data-source-intake-template.md",
      "assets/decision-record-template.md",
      "assets/delivery-template.md",
      "assets/jd-evidence-rubric-template.md",
      "assets/screening-alert-policy.json",
      "eval/acceptance.md",
      "examples/README.md",
      "platforms/README.md",
      "references/compliance-baseline.md",
      "references/data-source-and-api-gate.md",
      "references/feishu-alert-contract.md",
      "references/interview-scheduling-api-contract.md",
      "references/professional-checklist.md",
      "references/resume-screening-compliance-method.md",
      "references/scenario-playbook.md",
      "scripts/inventory_local_resumes.py",
      "scripts/evaluate_screening_run.py",
      "scripts/validate_screening_spec.py",
      "skill.json"
    ]
  },
  "compliance": {
    "profile": "hr-recruiting",
    "baseline": "references/compliance-baseline.md",
    "decision_states": ["ALLOW", "REVIEW_REQUIRED", "COMPLIANCE_REJECTED"],
    "human_review_required_when_uncertain": true,
    "does_not_replace_system_controls_or_professional_advice": true
  }
}
