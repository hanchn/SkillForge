{
  "name": "job-description-generator",
  "display_name": "招聘需求与 JD 自动生成",
  "type": "portable-business-skill",
  "scope": "cross-platform",
  "version": "1.1.0",
  "owner_project": "SkillForge",
  "portable": true,
  "entrypoint": "SKILL.md",
  "category_path": ["人事招聘", "岗位与JD"],
  "description": "在招聘需求创建时自动生成可编辑候选人 JD、HR 精准岗位培训文档、内部岗位说明书和机器可读简历筛选规则。发起人只需修改确认，正常情况以 READY_FOR_HR 零沟通交给 HR 和自动简历筛选。",
  "search_keywords": [
    "创建招聘需求自动生成 JD",
    "HR 零沟通岗位培训文档",
    "screening-spec.json",
    "JD 修改与筛选规则同步",
    "READY_FOR_HR"
  ],
  "supported_platforms": ["Claude", "Codex", "GPT", "Manus", "Trae", "Qorder"],
  "inputs": {
    "required": ["岗位名称、招聘原因、主要结果和发起人"],
    "optional": ["部门、职级、人数、地点、用工方式、预算、岗位模板和公司上下文"]
  },
  "outputs": [
    "可编辑候选人 JD",
    "HR 精准岗位培训文档",
    "内部岗位说明书",
    "screening-spec.json",
    "状态、版本、一致性检查和异常清单"
  ],
  "implementation": {
    "readme": "README.md",
    "entry_doc": "SKILL.md",
    "invocation_doc": "INVOCATION.md",
    "script": "",
    "config": "assets/screening-spec-template.json",
    "base_prompt": "BASE_PROMPT.md",
    "examples_dir": "examples",
    "eval_dir": "eval",
    "platform_adapters_dir": "platforms"
  },
  "constraints": [
    "不得虚构岗位、待遇或公司事实，不得以敏感属性或无关代理变量生成筛选标准。",
    "正常流程直接生成，只有关键冲突才进入 REVIEW_REQUIRED。",
    "岗位要求变化必须同步全部产物并递增 rubric 版本。"
  ],
  "distribution": {
    "share_as_single_folder": true,
    "required_files": ["SKILL.md", "skill.json", "README.md", "INVOCATION.md", "BASE_PROMPT.md"],
    "package_files": [
      "BASE_PROMPT.md",
      "INVOCATION.md",
      "README.md",
      "SKILL.md",
      "agents/openai.yaml",
      "assets/blank-jd-template.md",
      "assets/data-source-intake-template.md",
      "assets/decision-record-template.md",
      "assets/delivery-template.md",
      "assets/job-market-research-template.md",
      "assets/screening-spec-template.json",
      "eval/acceptance.md",
      "examples/README.md",
      "platforms/README.md",
      "references/compliance-baseline.md",
      "references/data-source-and-api-gate.md",
      "references/hr-role-training-checklist.md",
      "references/job-market-research-method.md",
      "references/professional-checklist.md",
      "references/scenario-playbook.md",
      "skill.json"
    ]
  },
  "compliance": {
    "profile": "hr-recruiting",
    "baseline": "references/compliance-baseline.md",
    "decision_states": ["ALLOW", "REVIEW_REQUIRED", "COMPLIANCE_REJECTED"],
    "human_review_required_when_uncertain": true,
    "does_not_replace_system_controls_or_professional_advice": true
  }
}
