{
  "name": "warehouse-safety-capacity-manager",
  "display_name": "仓容、现场安全与连续性经理",
  "type": "portable-business-skill",
  "scope": "cross-platform",
  "version": "1.0.2",
  "owner_project": "SkillForge",
  "portable": true,
  "entrypoint": "SKILL.md",
  "category_path": [
    "仓储库存",
    "仓容安全"
  ],
  "description": "管理仓容、库位、动线、设备、人员安全、消防、危险品、峰值产能和业务连续性。适用于新仓或仓库扩容、大促峰值仓容与人效规划、仓库安全检查和中断应急，交付仓容与产能模型、现场安全和检查清单、峰值、故障、灾害和恢复预案。",
  "search_keywords": [
    "新仓或仓库扩容",
    "大促峰值仓容与人效规划",
    "仓库安全检查和中断应急",
    "库位、容积、重量和周转",
    "收发存动线与人车分离",
    "设备、消防、用电和人体工学"
  ],
  "supported_platforms": [
    "Claude",
    "Codex",
    "GPT",
    "Manus",
    "Trae",
    "Qorder"
  ],
  "inputs": {
    "required": [
      "业务目标、范围和现状证据"
    ],
    "optional": [
      "历史数据、流程系统资料、目标、预算、SLA 和合规约束"
    ]
  },
  "outputs": [
    "仓容与产能模型",
    "现场安全和检查清单",
    "峰值、故障、灾害和恢复预案",
    "决策、执行、验收、风险和未知项记录"
  ],
  "implementation": {
    "readme": "README.md",
    "entry_doc": "SKILL.md",
    "invocation_doc": "INVOCATION.md",
    "script": "",
    "config": "",
    "base_prompt": "BASE_PROMPT.md",
    "examples_dir": "examples",
    "eval_dir": "eval",
    "platform_adapters_dir": "platforms"
  },
  "constraints": [
    "不得用效率目标突破消防、承重、设备、劳动和危险品安全限制；具体法定要求必须由当地合格人员确认。",
    "不得虚构事实、数据、权限、实施或验证结果",
    "必须明确口径、责任、验收、风险和未知项"
  ],
  "distribution": {
    "share_as_single_folder": true,
    "required_files": [
      "SKILL.md",
      "skill.json",
      "README.md",
      "INVOCATION.md",
      "BASE_PROMPT.md"
    ],
    "package_files": [
      "BASE_PROMPT.md",
      "INVOCATION.md",
      "README.md",
      "SKILL.md",
      "agents/openai.yaml",
      "assets/decision-record-template.md",
      "assets/delivery-template.md",
      "eval/acceptance.md",
      "examples/README.md",
      "platforms/README.md",
      "references/compliance-baseline.md",
      "references/professional-checklist.md",
      "references/scenario-playbook.md",
      "skill.json"
    ]
  },
  "compliance": {
    "profile": "warehouse-inventory",
    "baseline": "references/compliance-baseline.md",
    "decision_states": [
      "ALLOW",
      "REVIEW_REQUIRED",
      "COMPLIANCE_REJECTED"
    ],
    "human_review_required_when_uncertain": true,
    "does_not_replace_system_controls_or_professional_advice": true
  }
}
