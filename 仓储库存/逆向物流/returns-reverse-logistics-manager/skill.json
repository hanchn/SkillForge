{
  "name": "returns-reverse-logistics-manager",
  "display_name": "退货与逆向物流经理",
  "type": "portable-business-skill",
  "scope": "cross-platform",
  "version": "1.0.2",
  "owner_project": "SkillForge",
  "portable": true,
  "entrypoint": "SKILL.md",
  "category_path": [
    "仓储库存",
    "逆向物流"
  ],
  "description": "管理退货授权、运输、收货、检验、分级、退款证据、翻新、再售、报废和供应商追偿。适用于客户退货处理、平台退仓和批量逆向、残次、翻新、再售与报废治理，交付逆向流程与状态机、检验分级和处置标准、退款、库存、追偿和根因报告。",
  "search_keywords": [
    "客户退货处理",
    "平台退仓和批量逆向",
    "残次、翻新、再售与报废治理",
    "RMA、订单、原因和责任",
    "运输、收货、身份和完整性",
    "检验、分级、清洁和翻新"
  ],
  "supported_platforms": [
    "Claude",
    "Codex",
    "GPT",
    "Manus",
    "Trae",
    "Qorder"
  ],
  "inputs": {
    "required": [
      "业务目标、范围和现状证据"
    ],
    "optional": [
      "历史数据、流程系统资料、目标、预算、SLA 和合规约束"
    ]
  },
  "outputs": [
    "逆向流程与状态机",
    "检验分级和处置标准",
    "退款、库存、追偿和根因报告",
    "决策、执行、验收、风险和未知项记录"
  ],
  "implementation": {
    "readme": "README.md",
    "entry_doc": "SKILL.md",
    "invocation_doc": "INVOCATION.md",
    "script": "",
    "config": "",
    "base_prompt": "BASE_PROMPT.md",
    "examples_dir": "examples",
    "eval_dir": "eval",
    "platform_adapters_dir": "platforms"
  },
  "constraints": [
    "不得未经检验把退货恢复可售；涉及安全、卫生、个人数据或召回的商品必须隔离并按专项规则处置。",
    "不得虚构事实、数据、权限、实施或验证结果",
    "必须明确口径、责任、验收、风险和未知项"
  ],
  "distribution": {
    "share_as_single_folder": true,
    "required_files": [
      "SKILL.md",
      "skill.json",
      "README.md",
      "INVOCATION.md",
      "BASE_PROMPT.md"
    ],
    "package_files": [
      "BASE_PROMPT.md",
      "INVOCATION.md",
      "README.md",
      "SKILL.md",
      "agents/openai.yaml",
      "assets/decision-record-template.md",
      "assets/delivery-template.md",
      "eval/acceptance.md",
      "examples/README.md",
      "platforms/README.md",
      "references/compliance-baseline.md",
      "references/professional-checklist.md",
      "references/scenario-playbook.md",
      "skill.json"
    ]
  },
  "compliance": {
    "profile": "warehouse-inventory",
    "baseline": "references/compliance-baseline.md",
    "decision_states": [
      "ALLOW",
      "REVIEW_REQUIRED",
      "COMPLIANCE_REJECTED"
    ],
    "human_review_required_when_uncertain": true,
    "does_not_replace_system_controls_or_professional_advice": true
  }
}
