{
  "name": "sample-evaluation-sourcing-manager",
  "display_name": "采购样品验证经理",
  "type": "portable-business-skill",
  "scope": "cross-platform",
  "version": "1.0.0",
  "owner_project": "SkillForge",
  "portable": true,
  "entrypoint": "SKILL.md",
  "category_path": [
    "市场采购",
    "样品验证"
  ],
  "description": "管理打样需求、样品版本、功能外观评估、成本、测试、用户验证和量产放行证据。适用于新品打样和多供应商比样、样品改版和确认、量产前样、封样和放行，交付样品需求与版本台账、比样、测试和问题矩阵、修改、封样、量产和否决决定。",
  "search_keywords": [
    "新品打样和多供应商比样",
    "样品改版和确认",
    "量产前样、封样和放行",
    "规格、BOM、外观和使用场景",
    "供应商、版本、日期和样品身份",
    "功能、耐久、安全和包装测试"
  ],
  "supported_platforms": [
    "Claude",
    "Codex",
    "GPT",
    "Manus",
    "Trae",
    "Qorder"
  ],
  "inputs": {
    "required": [
      "业务目标、范围和现状证据"
    ],
    "optional": [
      "历史数据、流程系统资料、目标、预算、SLA 和合规约束"
    ]
  },
  "outputs": [
    "样品需求与版本台账",
    "比样、测试和问题矩阵",
    "修改、封样、量产和否决决定",
    "决策、执行、验收、风险和未知项记录"
  ],
  "implementation": {
    "readme": "README.md",
    "entry_doc": "SKILL.md",
    "invocation_doc": "INVOCATION.md",
    "script": "",
    "config": "",
    "base_prompt": "BASE_PROMPT.md",
    "examples_dir": "examples",
    "eval_dir": "eval",
    "platform_adapters_dir": "platforms"
  },
  "constraints": [
    "不得凭主观外观或单个样品直接量产；关键规格、测试、缺陷和版本必须可追溯并经授权角色签核。",
    "不得虚构事实、数据、权限、实施或验证结果",
    "必须明确口径、责任、验收、风险和未知项"
  ],
  "distribution": {
    "share_as_single_folder": true,
    "required_files": [
      "SKILL.md",
      "skill.json",
      "README.md",
      "INVOCATION.md",
      "BASE_PROMPT.md"
    ],
    "package_files": [
      "BASE_PROMPT.md",
      "INVOCATION.md",
      "README.md",
      "SKILL.md",
      "agents/openai.yaml",
      "assets/delivery-template.md",
      "eval/acceptance.md",
      "examples/README.md",
      "platforms/README.md",
      "references/professional-checklist.md",
      "skill.json"
    ]
  }
}
