{
  "name": "purchase-order-delivery-manager",
  "display_name": "采购订单与交付经理",
  "type": "portable-business-skill",
  "scope": "cross-platform",
  "version": "1.0.5",
  "owner_project": "SkillForge",
  "portable": true,
  "entrypoint": "SKILL.md",
  "category_path": [
    "市场采购",
    "采购执行"
  ],
  "description": "管理采购申请、订单、确认、预付款、生产、质检、交付、变更、异常和关闭。适用于采购订单下达、生产和交期跟踪、数量价格交付变更与异常处理，交付采购订单与里程碑台账、交期、质量和付款跟踪、变更、索赔、关闭和供应商绩效记录。",
  "search_keywords": [
    "采购订单下达",
    "生产和交期跟踪",
    "数量价格交付变更与异常处理",
    "申请、预算、合同和审批",
    "SKU、规格、数量、价格和币种",
    "生产、质检、装运和到仓节点"
  ],
  "supported_platforms": [
    "Claude",
    "Codex",
    "GPT",
    "Manus",
    "Trae",
    "Qorder"
  ],
  "inputs": {
    "required": [
      "业务目标、范围和现状证据"
    ],
    "optional": [
      "历史数据、流程系统资料、目标、预算、SLA 和合规约束"
    ]
  },
  "outputs": [
    "采购订单与里程碑台账",
    "交期、质量和付款跟踪",
    "变更、索赔、关闭和供应商绩效记录",
    "决策、执行、验收、风险和未知项记录"
  ],
  "implementation": {
    "readme": "README.md",
    "entry_doc": "SKILL.md",
    "invocation_doc": "INVOCATION.md",
    "script": "",
    "config": "",
    "base_prompt": "BASE_PROMPT.md",
    "examples_dir": "examples",
    "eval_dir": "eval",
    "platform_adapters_dir": "platforms"
  },
  "constraints": [
    "不得在缺少授权、规格、价格、交付或付款条件时下单；订单变更必须保留原版本、影响、批准和供应商确认。",
    "不得虚构事实、数据、权限、实施或验证结果",
    "必须明确口径、责任、验收、风险和未知项"
  ],
  "distribution": {
    "share_as_single_folder": true,
    "required_files": [
      "SKILL.md",
      "skill.json",
      "README.md",
      "INVOCATION.md",
      "BASE_PROMPT.md"
    ],
    "package_files": [
      "BASE_PROMPT.md",
      "INVOCATION.md",
      "README.md",
      "SKILL.md",
      "agents/openai.yaml",
      "assets/data-source-intake-template.md",
      "assets/decision-record-template.md",
      "assets/delivery-template.md",
      "eval/acceptance.md",
      "examples/README.md",
      "platforms/README.md",
      "references/compliance-baseline.md",
      "references/data-source-and-api-gate.md",
      "references/professional-checklist.md",
      "references/scenario-playbook.md",
      "skill.json"
    ]
  },
  "compliance": {
    "profile": "market-procurement",
    "baseline": "references/compliance-baseline.md",
    "decision_states": [
      "ALLOW",
      "REVIEW_REQUIRED",
      "COMPLIANCE_REJECTED"
    ],
    "human_review_required_when_uncertain": true,
    "does_not_replace_system_controls_or_professional_advice": true
  }
}
