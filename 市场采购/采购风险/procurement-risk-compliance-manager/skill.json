{
  "name": "procurement-risk-compliance-manager",
  "display_name": "采购风险与供应韧性经理",
  "type": "portable-business-skill",
  "scope": "cross-platform",
  "version": "1.0.2",
  "owner_project": "SkillForge",
  "portable": true,
  "entrypoint": "SKILL.md",
  "category_path": [
    "市场采购",
    "采购风险"
  ],
  "description": "识别供应商、产地、材料、质量、合规、制裁、集中度、产能、灾害和商业连续性风险。适用于新供应商准入、单一来源和供应中断治理、采购合规与供应链尽调，交付采购风险与责任矩阵、供应商尽调和证据缺口、替代来源、缓解、监控和升级计划。",
  "search_keywords": [
    "新供应商准入",
    "单一来源和供应中断治理",
    "采购合规与供应链尽调",
    "主体、所有权和经营资质",
    "产地、材料、劳工和环境证据",
    "制裁、出口管制和产品合规"
  ],
  "supported_platforms": [
    "Claude",
    "Codex",
    "GPT",
    "Manus",
    "Trae",
    "Qorder"
  ],
  "inputs": {
    "required": [
      "业务目标、范围和现状证据"
    ],
    "optional": [
      "历史数据、流程系统资料、目标、预算、SLA 和合规约束"
    ]
  },
  "outputs": [
    "采购风险与责任矩阵",
    "供应商尽调和证据缺口",
    "替代来源、缓解、监控和升级计划",
    "决策、执行、验收、风险和未知项记录"
  ],
  "implementation": {
    "readme": "README.md",
    "entry_doc": "SKILL.md",
    "invocation_doc": "INVOCATION.md",
    "script": "",
    "config": "",
    "base_prompt": "BASE_PROMPT.md",
    "examples_dir": "examples",
    "eval_dir": "eval",
    "platform_adapters_dir": "platforms"
  },
  "constraints": [
    "不得把供应商自我声明当作充分证据；制裁、强迫劳动、重大质量或产品安全红旗必须暂停并升级法务与合规人员。",
    "不得虚构事实、数据、权限、实施或验证结果",
    "必须明确口径、责任、验收、风险和未知项"
  ],
  "distribution": {
    "share_as_single_folder": true,
    "required_files": [
      "SKILL.md",
      "skill.json",
      "README.md",
      "INVOCATION.md",
      "BASE_PROMPT.md"
    ],
    "package_files": [
      "BASE_PROMPT.md",
      "INVOCATION.md",
      "README.md",
      "SKILL.md",
      "agents/openai.yaml",
      "assets/decision-record-template.md",
      "assets/delivery-template.md",
      "eval/acceptance.md",
      "examples/README.md",
      "platforms/README.md",
      "references/compliance-baseline.md",
      "references/professional-checklist.md",
      "references/scenario-playbook.md",
      "skill.json"
    ]
  },
  "compliance": {
    "profile": "market-procurement",
    "baseline": "references/compliance-baseline.md",
    "decision_states": [
      "ALLOW",
      "REVIEW_REQUIRED",
      "COMPLIANCE_REJECTED"
    ],
    "human_review_required_when_uncertain": true,
    "does_not_replace_system_controls_or_professional_advice": true
  }
}
