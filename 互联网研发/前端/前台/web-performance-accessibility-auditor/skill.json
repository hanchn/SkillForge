{
  "name": "web-performance-accessibility-auditor",
  "display_name": "Web 性能与无障碍审计师",
  "type": "portable-business-skill",
  "scope": "cross-platform",
  "version": "1.0.4",
  "owner_project": "SkillForge",
  "portable": true,
  "entrypoint": "SKILL.md",
  "category_path": [
    "互联网研发",
    "前端",
    "前台",
    "质量审计"
  ],
  "description": "Audit and improve web performance, Core Web Vitals, loading behavior, semantic HTML, keyboard access, focus management, screen-reader communication, contrast, motion, responsive interaction, and regression risk using measured evidence",
  "search_keywords": [
    "前台",
    "质量审计",
    "审计商品页或业务流程的 Core Web Vitals",
    "检查表单、弹层和动态内容无障碍",
    "发布前建立性能预算和回归门槛"
  ],
  "supported_platforms": [
    "Claude",
    "Codex",
    "GPT",
    "Manus",
    "Trae",
    "Qorder"
  ],
  "inputs": {
    "required": [
      "URL、构建或页面代码"
    ],
    "optional": [
      "目标设备、网络和关键旅程",
      "可选 RUM、性能 trace、无障碍报告和用户反馈"
    ]
  },
  "outputs": [
    "性能与无障碍审计",
    "根因和优先级 backlog",
    "修复验收与复测结果",
    "预算和监控建议"
  ],
  "implementation": {
    "readme": "README.md",
    "entry_doc": "SKILL.md",
    "invocation_doc": "INVOCATION.md",
    "script": "",
    "config": "",
    "base_prompt": "BASE_PROMPT.md",
    "examples_dir": "examples",
    "eval_dir": "eval",
    "platform_adapters_dir": "platforms"
  },
  "constraints": [
    "不得只凭 Lighthouse 单次分数下结论",
    "不得用 aria 修补本可用原生语义解决的问题",
    "不得通过隐藏内容、延迟交互或删除功能制造虚假性能提升",
    "不得声称自动扫描已覆盖全部无障碍问题"
  ],
  "distribution": {
    "share_as_single_folder": true,
    "required_files": [
      "SKILL.md",
      "skill.json",
      "README.md",
      "INVOCATION.md",
      "BASE_PROMPT.md"
    ],
    "package_files": [
      "BASE_PROMPT.md",
      "INVOCATION.md",
      "README.md",
      "SKILL.md",
      "agents/openai.yaml",
      "assets/data-source-intake-template.md",
      "assets/decision-record-template.md",
      "assets/web-quality-report-template.md",
      "eval/acceptance.md",
      "examples/README.md",
      "platforms/README.md",
      "references/audit-checklist.md",
      "references/compliance-baseline.md",
      "references/data-source-and-api-gate.md",
      "references/scenario-playbook.md",
      "skill.json"
    ]
  },
  "compliance": {
    "profile": "product-engineering",
    "baseline": "references/compliance-baseline.md",
    "decision_states": [
      "ALLOW",
      "REVIEW_REQUIRED",
      "COMPLIANCE_REJECTED"
    ],
    "human_review_required_when_uncertain": true,
    "does_not_replace_system_controls_or_professional_advice": true
  }
}
