  "implementation": {
    "readme": "README.md",
    "entry_doc": "SKILL.md",
    "invocation_doc": "INVOCATION.md",
    "script": "",
    "config": "",
    "base_prompt": "BASE_PROMPT.md",
    "examples_dir": "examples",
    "eval_dir": "eval",
    "platform_adapters_dir": "platforms"
  },
  "constraints": [
    "不得用端到端用例替代所有低层精确验证",
    "不得只测接口 200 或页面出现而忽略数据和副作用",
    "不得在共享环境制造不可清理或敏感测试数据",
    "不得因测试通过忽略观测、迁移和回滚不可验证"
