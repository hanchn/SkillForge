  "supported_platforms": [
    "Claude",
    "Codex",
    "GPT",
    "Manus",
    "Trae",
    "Qorder"
  ],
  "inputs": {
    "required": [
      "需求、架构和变更范围"
    ],
    "optional": [
      "测试环境、数据、身份和依赖",
      "发布、迁移、监控和事故背景"
    ]
  },
  "outputs": [
