    "预约、收货、质检和上架",
    "波次、拣选、复核和包装"
  ],
  "supported_platforms": [
    "Claude",
    "Codex",
    "GPT",
    "Manus",
    "Trae",
    "Qorder"
  ],
  "inputs": {
    "required": [
      "业务目标、范围和现状证据"
    ],
    "optional": [
      "历史数据、流程系统资料、目标、预算、SLA 和合规约束"
    ]
  },
  "outputs": [
    "WMS 能力地图",
    "仓内任务与状态机",
    "作业、设备、异常和集成方案",
    "决策、执行、验收、风险和未知项记录"
