  ],
  "description": "围绕统一客户、同意偏好、互动、服务、分群和生命周期运营设计 CRM 产品架构。适用于跨渠道客户中心、营销与客服 CRM、客户 360 和生命周期运营，交付CRM 能力地图、客户身份与同意模型、互动、分群、任务和集成方案。",
  "search_keywords": [
    "跨渠道客户中心",
    "营销与客服 CRM",
    "客户 360 和生命周期运营",
    "客户身份合并与冲突",
    "同意、偏好和隐私请求",
    "订单、互动和服务视图"
  ],
  "supported_platforms": [
    "Claude",
    "Codex",
    "GPT",
    "Manus",
    "Trae",
    "Qorder"
  ],
  "inputs": {
    "required": [
      "业务目标、范围和现状证据"
    ],
    "optional": [
      "历史数据、流程系统资料、目标、预算、SLA 和合规约束"
    ]
  },
  "outputs": [
    "CRM 能力地图",
    "客户身份与同意模型",
    "互动、分群、任务和集成方案",
    "决策、执行、验收、风险和未知项记录"
  ],
  "implementation": {
    "readme": "README.md",
    "entry_doc": "SKILL.md",
    "invocation_doc": "INVOCATION.md",
    "script": "",
    "config": "",
    "base_prompt": "BASE_PROMPT.md",
    "examples_dir": "examples",
    "eval_dir": "eval",
    "platform_adapters_dir": "platforms"
  },
  "constraints": [
    "不得把无法证明为同一人的身份强行合并，也不得绕过同意使用数据。",
    "不得虚构事实、数据、权限、实施或验证结果",
    "必须明确口径、责任、验收、风险和未知项"
  ],
  "distribution": {
