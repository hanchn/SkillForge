{
  "name": "label-governance-workflow-designer",
  "display_name": "标签治理与审核工作流设计师",
  "type": "portable-business-skill",
  "scope": "cross-platform",
  "version": "1.0.5",
  "owner_project": "SkillForge",
  "portable": true,
  "entrypoint": "SKILL.md",
