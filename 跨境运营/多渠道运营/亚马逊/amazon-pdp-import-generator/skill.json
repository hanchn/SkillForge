{
  "name": "amazon-pdp-import-generator",
  "display_name": "亚马逊PDP内容生成技能",
  "type": "portable-business-skill",
  "scope": "cross-platform",
  "version": "1.0.0",
  "owner_project": "SkillForge",
  "portable": true,
  "entrypoint": "SKILL.md",
  "category_path": [
    "跨境运营",
    "多渠道运营",
    "亚马逊"
  ],
  "description": "根据商品图片文件名自动生成亚马逊 PDP 内容和导入草稿文件，支持商品信息提取与多平台 AI 复用。",
  "search_keywords": [
    "亚马逊",
    "PDP",
    "内容生成",
    "商品信息",
    "图片识别",
    "表格生成"
  ],
  "supported_platforms": [
    "Claude",
    "Codex",
    "GPT",
    "Manus",
    "Trae",
    "Qorder"
  ],
  "inputs": {
    "required": [
      "image_folder_path"
    ],
    "optional": [
      "brand",
      "marketplace",
      "category",
      "variation_theme"
    ]
  },
  "outputs": [
    "amazon_pdp_import_draft.xlsx",
    "amazon_pdp_import_draft.csv"
  ],
  "implementation": {
    "readme": "README.md",
    "entry_doc": "SKILL.md",
    "invocation_doc": "INVOCATION.md",
    "script": "scripts/generate_pdp_import.py",
    "config": "assets/parser_config.json",
    "base_prompt": "BASE_PROMPT.md",
    "examples_dir": "examples",
    "eval_dir": "eval",
    "platform_adapters_dir": "platforms"
  },
  "constraints": [
    "README.md 只是说明文件",
    "不要把 skill 放进 .trae",
    "优先复用现有脚本，不重复造轮子",
    "目录为空时不得伪造结果"
  ],
  "distribution": {
    "share_as_single_folder": true,
    "required_files": [
      "SKILL.md",
      "skill.json",
      "README.md",
      "INVOCATION.md",
      "BASE_PROMPT.md",
      "scripts/generate_pdp_import.py",
      "assets/parser_config.json"
    ],
    "package_files": [
      "SKILL.md",
      "skill.json",
      "README.md",
      "INVOCATION.md",
      "BASE_PROMPT.md",
      "scripts/generate_pdp_import.py",
      "assets/parser_config.json",
      "examples/README.md",
      "examples/sample_input_files.txt",
      "examples/sample_output.csv",
      "eval/acceptance.md",
      "platforms/claude.md",
      "platforms/codex.md",
      "platforms/gpt.md",
      "platforms/manus.md",
      "platforms/qorder.md",
      "platforms/trae.md"
    ]
  }
}
