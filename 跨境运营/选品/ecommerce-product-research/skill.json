{
  "name": "ecommerce-product-research",
  "display_name": "跨境电商选品研究",
  "type": "portable-business-skill",
  "scope": "cross-platform",
  "version": "1.0.0",
  "owner_project": "SkillForge",
  "portable": true,
  "entrypoint": "SKILL.md",
  "category_path": [
    "跨境运营",
    "选品",
    "跨渠道机会研究"
  ],
  "description": "从需求、竞争、利润、供应链、合规和渠道适配评估跨境产品机会",
  "search_keywords": [
    "选品",
    "产品研究",
    "市场机会",
    "利润模型",
    "供应链",
    "Amazon",
    "Shopify",
    "TikTok Shop"
  ],
  "supported_platforms": [
    "Claude",
    "Codex",
    "GPT",
    "Manus",
    "Trae",
    "Qorder"
  ],
  "inputs": {
    "required": [
      "candidate_product_or_category",
      "target_market"
    ],
    "optional": [
      "channel_options",
      "budget",
      "margin_floor",
      "supplier_data",
      "research_sources"
    ]
  },
  "outputs": [
    "product_opportunity_report.md",
    "scenario_economics.md",
    "validation_plan.md"
  ],
  "implementation": {
    "readme": "README.md",
    "entry_doc": "SKILL.md",
    "invocation_doc": "INVOCATION.md",
    "script": "",
    "config": "",
    "base_prompt": "BASE_PROMPT.md",
    "examples_dir": "examples",
    "eval_dir": "eval",
    "platform_adapters_dir": "platforms"
  },
  "constraints": [
    "不虚构销量、搜索量、费用、认证或供应商报价",
    "不把第三方估算当成真实交易数据",
    "不因综合分数高而忽略致命合规或现金流风险"
  ],
  "distribution": {
    "share_as_single_folder": true,
    "required_files": [
      "SKILL.md",
      "skill.json",
      "README.md",
      "INVOCATION.md",
      "BASE_PROMPT.md"
    ],
    "package_files": [
      "SKILL.md",
      "skill.json",
      "README.md",
      "INVOCATION.md",
      "BASE_PROMPT.md",
      "agents/openai.yaml",
      "references",
      "assets",
      "examples",
      "eval",
      "platforms"
    ]
  }
}
