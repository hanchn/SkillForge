    ],
    "optional": [
      "target_market",
      "business_facts",
      "url",
      "keyword_or_serp_data",
      "performance_data"
    ]
  },
  "outputs": [
    "seo_audit_or_content.md",
    "keyword_intent_map.md",
    "measurement_plan.md"
