{
  "name": "ai-image-video-production-manager",
  "display_name": "AI 图片与视频成片专家",
  "type": "portable-business-skill",
  "scope": "cross-platform",
  "version": "1.0.0",
  "owner_project": "SkillForge",
  "portable": true,
  "entrypoint": "SKILL.md",
  "category_path": [
    "创意拍摄",
    "AI创意制作",
    "AI成片"
  ],
  "description": "把商品事实、品牌规范、脚本和参考素材编排为可追溯的 AI 图片、视频生成与合成交付流程。适用于AI 商品场景图和广告图、文生视频、图生视频和镜头扩展、批量多语言多比例创意成片，交付AI 成片制作方案和模型路由、提示词、参考、参数与版本记录、候选筛选、人工修正和交付质检包。",
  "search_keywords": [
    "AI 商品场景图和广告图",
    "文生视频、图生视频和镜头扩展",
    "批量多语言多比例创意成片",
    "商品事实锁定与参考图",
    "模型、输入输出、参数和随机种",
    "镜头连续性、运动和物理合理性"
  ],
  "supported_platforms": [
    "Claude",
    "Codex",
    "GPT",
    "Manus",
    "Trae",
    "Qorder"
  ],
  "inputs": {
    "required": [
      "业务目标、范围和现状证据"
    ],
    "optional": [
      "历史数据、流程系统资料、目标、预算、SLA 和合规约束"
    ]
  },
  "outputs": [
    "AI 成片制作方案和模型路由",
    "提示词、参考、参数与版本记录",
    "候选筛选、人工修正和交付质检包",
    "决策、执行、验收、风险和未知项记录"
  ],
  "implementation": {
    "readme": "README.md",
    "entry_doc": "SKILL.md",
    "invocation_doc": "INVOCATION.md",
    "script": "",
    "config": "",
    "base_prompt": "BASE_PROMPT.md",
    "examples_dir": "examples",
    "eval_dir": "eval",
    "platform_adapters_dir": "platforms"
  },
  "constraints": [
    "不得把生成结果当作真实拍摄证据；关键商品特征、文字、标识、人物和声明必须逐项人工核验，并保留输入、模型与修改血缘。",
    "不得虚构事实、数据、权限、实施或验证结果",
    "必须明确口径、责任、验收、风险和未知项"
  ],
  "distribution": {
    "share_as_single_folder": true,
    "required_files": [
      "SKILL.md",
      "skill.json",
      "README.md",
      "INVOCATION.md",
      "BASE_PROMPT.md"
    ],
    "package_files": [
      "BASE_PROMPT.md",
      "INVOCATION.md",
      "README.md",
      "SKILL.md",
      "agents/openai.yaml",
      "assets/delivery-template.md",
      "eval/acceptance.md",
      "examples/README.md",
      "platforms/README.md",
      "references/professional-checklist.md",
      "skill.json"
    ]
  }
}
