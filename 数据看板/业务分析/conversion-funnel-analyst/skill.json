{
  "name": "conversion-funnel-analyst",
  "display_name": "电商转化漏斗分析师",
  "type": "portable-business-skill",
  "scope": "cross-platform",
  "version": "1.0.0",
  "owner_project": "SkillForge",
  "portable": true,
  "entrypoint": "SKILL.md",
  "category_path": [
    "数据看板",
    "业务分析"
  ],
  "description": "按一致人群、事件和时间窗定位从曝光到购买的转化损失。适用于商品或结账转化下降、设备国家渠道漏斗比较、改版和实验效果诊断，交付漏斗诊断、流失分层和证据、实验与修复优先级。",
  "search_keywords": [
    "商品或结账转化下降",
    "设备国家渠道漏斗比较",
    "改版和实验效果诊断",
    "漏斗定义和可比 cohort",
    "曝光、查看、加购、结账和购买",
    "设备、页面、国家和渠道"
  ],
  "supported_platforms": [
    "Claude",
    "Codex",
    "GPT",
    "Manus",
    "Trae",
    "Qorder"
  ],
  "inputs": {
    "required": [
      "业务目标、范围和现状证据"
    ],
    "optional": [
      "历史数据、流程系统资料、目标、预算、SLA 和合规约束"
    ]
  },
  "outputs": [
    "漏斗诊断",
    "流失分层和证据",
    "实验与修复优先级",
    "决策、执行、验收、风险和未知项记录"
  ],
  "implementation": {
    "readme": "README.md",
    "entry_doc": "SKILL.md",
    "invocation_doc": "INVOCATION.md",
    "script": "",
    "config": "",
    "base_prompt": "BASE_PROMPT.md",
    "examples_dir": "examples",
    "eval_dir": "eval",
    "platform_adapters_dir": "platforms"
  },
  "constraints": [
    "不得把不同人群的阶段比率拼成伪漏斗。",
    "不得虚构事实、数据、权限、实施或验证结果",
    "必须明确口径、责任、验收、风险和未知项"
  ],
  "distribution": {
    "share_as_single_folder": true,
    "required_files": [
      "SKILL.md",
      "skill.json",
      "README.md",
      "INVOCATION.md",
      "BASE_PROMPT.md"
    ],
    "package_files": [
      "BASE_PROMPT.md",
      "INVOCATION.md",
      "README.md",
      "SKILL.md",
      "agents/openai.yaml",
      "assets/delivery-template.md",
      "eval/acceptance.md",
      "examples/README.md",
      "platforms/README.md",
      "references/professional-checklist.md",
      "skill.json"
    ]
  }
}
