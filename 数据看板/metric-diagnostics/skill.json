{
  "name": "metric-diagnostics",
  "display_name": "业务指标诊断师",
  "type": "portable-business-skill",
  "scope": "cross-platform",
  "version": "1.0.1",
  "owner_project": "SkillForge",
  "portable": true,
  "entrypoint": "SKILL.md",
  "category_path": [
    "数据看板",
    "业务分析",
    "指标诊断"
  ],
  "description": "验证指标口径与数据质量，量化拆解异常变化并区分驱动因素和假设",
  "search_keywords": [
    "指标异常",
    "数据诊断",
    "归因",
    "漏斗",
    "贡献度",
    "数据质量"
  ],
  "supported_platforms": [
    "Claude",
    "Codex",
    "GPT",
    "Manus",
    "Trae",
    "Qorder"
  ],
  "inputs": {
    "required": [
      "metric_and_comparison"
    ],
    "optional": [
      "queries_or_files",
      "dashboard",
      "change_log",
      "segments"
    ]
  },
  "outputs": [
    "metric_diagnostic.md",
    "contribution_table",
    "hypothesis_scorecard"
  ],
  "implementation": {
    "readme": "README.md",
    "entry_doc": "SKILL.md",
    "invocation_doc": "INVOCATION.md",
    "script": "",
    "config": "",
    "base_prompt": "BASE_PROMPT.md",
    "examples_dir": "examples",
    "eval_dir": "eval",
    "platform_adapters_dir": "platforms"
  },
  "constraints": [
    "不把相关性写成因果",
    "不比较不完整与完整周期而不说明",
    "不以小样本百分比变化代替贡献度"
  ],
  "distribution": {
    "share_as_single_folder": true,
    "required_files": [
      "SKILL.md",
      "skill.json",
      "README.md",
      "INVOCATION.md",
      "BASE_PROMPT.md"
    ],
    "package_files": [
      "BASE_PROMPT.md",
      "INVOCATION.md",
      "README.md",
      "SKILL.md",
      "agents/openai.yaml",
      "assets/diagnostic-report-template.md",
      "eval/acceptance.md",
      "examples/README.md",
      "platforms/README.md",
      "references/compliance-baseline.md",
      "references/diagnostic-method.md",
      "skill.json"
    ]
  },
  "compliance": {
    "profile": "data-analytics",
    "baseline": "references/compliance-baseline.md",
    "decision_states": [
      "ALLOW",
      "REVIEW_REQUIRED",
      "COMPLIANCE_REJECTED"
    ],
    "human_review_required_when_uncertain": true,
    "does_not_replace_system_controls_or_professional_advice": true
  }
}
