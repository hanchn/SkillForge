{
  "name": "cross-border-tax-vat-planner",
  "display_name": "跨境税务与 VAT 规划师",
  "type": "portable-business-skill",
  "scope": "cross-platform",
  "version": "1.0.2",
  "owner_project": "SkillForge",
  "portable": true,
  "entrypoint": "SKILL.md",
  "category_path": [
    "财务出纳",
    "税务合规"
